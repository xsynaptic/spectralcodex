# Config-time variables (used by Vite loadEnv in astro.config.mjs)
DEV_SERVER_URL=http://localhost:4321/
PROD_SERVER_URL=
BUILD_ASSETS_PATH=_x

# Content paths (defaults to demo content if unset)
CONTENT_DATA_PATH=
CONTENT_MEDIA_PATH=

# Map
MAP_PROTOMAPS_API_KEY=

# Analytics
UMAMI_DOMAIN=
UMAMI_ID=

# Image server (dev defaults to /_img, proxied to localhost:3100 by Astro dev server)
IMAGE_SERVER_URL=
IMAGE_SERVER_SECRET=
IMAGE_SERVER_SIGNATURE_LENGTH=

# Webmentions
WEBMENTION_API_KEY=
WEBMENTION_DOMAIN=

# Cache directory
CUSTOM_CACHE_PATH=
