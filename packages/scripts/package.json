		"image-server-manifest": "tsx --env-file-if-exists=../../.env ./src/image-server/manifest.ts",
		"image-server-warm": "tsx --env-file-if-exists=../../.env --env-file-if-exists=../../deploy/.env ./src/image-server/cache-warm.ts",
		"image-server-warm-new": "tsx --env-file-if-exists=../../.env --env-file-if-exists=../../deploy/.env ./src/image-server/cache-warm-new.ts",
		"map-divisions": "tsx ./src/map-divisions/index.ts",
		"media-orphans": "tsx ./src/media-orphans/index.ts",
		"check-links": "tsx ./src/check-links/index.ts",
		"og-image": "tsx ./src/og-image/index.ts"
	},
	"devDependencies": {
