{
	"name": "@spectralcodex/scripts",
	"version": "1.1.0",
	"description": "Scripts for Spectral Codex",
	"type": "module",
	"private": true,
	"scripts": {
		"content-related": "tsx ./src/content-related/index.ts",
		"content-schemas": "tsx ./src/content-schemas/index.ts",
		"content-validate": "tsx ./src/content-validate/index.ts",
		"deploy-site": "tsx --env-file-if-exists=../../.env --env-file-if-exists=../../deploy/.env ./src/deploy/deploy.ts",
		"deploy-app": "tsx --env-file-if-exists=../../.env --env-file-if-exists=../../deploy/.env ./src/deploy/deploy-app.ts",
		"deploy-caddy": "tsx --env-file-if-exists=../../.env --env-file-if-exists=../../deploy/.env ./src/deploy/deploy-caddy.ts",
		"deploy-cache-purge": "tsx --env-file-if-exists=../../deploy/.env ./src/deploy/deploy-cache-purge.ts",
		"deploy-image-server": "tsx --env-file-if-exists=../../.env --env-file-if-exists=../../deploy/.env ./src/deploy/deploy-image-server.ts",
		"deploy-media": "tsx --env-file-if-exists=../../.env --env-file-if-exists=../../deploy/.env ./src/deploy/deploy-media.ts",
		"deploy-og": "tsx --env-file-if-exists=../../.env --env-file-if-exists=../../deploy/.env ./src/deploy/deploy-og.ts",
		"dev-server": "tsx --env-file-if-exists=../../.env --env-file-if-exists=../../.env.development ./src/dev-server/index.ts",
