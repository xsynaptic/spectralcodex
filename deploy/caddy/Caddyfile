{
	# Trust Cloudflare's edge IPs so {client_ip} resolves to the real visitor, not the CF edge.
	# Ranges from https://www.cloudflare.com/ips/ (update if Cloudflare changes them).
	servers {
		trusted_proxies static 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22 2400:cb00::/32 2606:4700::/32 2803:f800::/32 2405:b500::/32 2405:8100::/32 2a06:98c0::/29 2c0f:f248::/32
	}
}

(spectralcodex-tls) {
	tls /certs/spectralcodex.com.pem /certs/spectralcodex.com.private.pem
}

www.spectralcodex.com {
	import spectralcodex-tls
	redir https://spectralcodex.com{uri} permanent
}

spectralcodex.com {
	import spectralcodex-tls
	root * /var/www/spectralcodex
	file_server
	encode gzip

	handle_errors {
		rewrite * /404.html
		file_server
	}

	@no_trailing_slash {
		path_regexp notrail ^(.+[^/])$
		not path_regexp \.[a-zA-Z0-9_-]+$
	}
	redir @no_trailing_slash {re.notrail.1}/ 301

	import spectralcodex-redirects.conf
	import spectralcodex-redirects-generated.conf

	# geolocation kept on self for the map's GeolocateControl
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy "geolocation=(self), camera=(), microphone=(), browsing-topics=()"
	}

	@immutable path /_x/*
	header @immutable Cache-Control "public, max-age=31536000, immutable"

	@static path *.css *.js *.jpg *.jpeg *.png *.gif *.svg *.webp *.avif *.woff2 *.woff
	header @static Cache-Control "public, max-age=31536000"

	@data path *.json *.fgb
	header @data Cache-Control "public, max-age=3600, s-maxage=86400, stale-while-revalidate=86400"

	@map_api path /api/map/*
	header @map_api Cache-Control "public, max-age=31536000, immutable"

	# Deploy manifest: stable URL, build-varying content; must not be immutable-cached
	@map_manifest path /api/map/map-manifest.json
	header @map_manifest Cache-Control "no-store"

	@html path *.html */
	header @html Cache-Control "public, max-age=3600, s-maxage=86400, stale-while-revalidate=86400"
	header @html No-Vary-Search `params=("utm_source" "utm_medium" "utm_campaign" "utm_content" "utm_term" "utm_id" "gclid" "fbclid" "mc_cid" "mc_eid"), key-order`
}

u.spectralcodex.com {
	import spectralcodex-tls
	handle /robots.txt {
		respond "User-agent: *
Disallow: /"
	}
	reverse_proxy umami:3000
}

img.spectralcodex.com {
	import spectralcodex-tls
	handle /robots.txt {
		respond "User-agent: *
Disallow: /"
	}
	reverse_proxy image-cache:80 {
		header_up X-Real-IP {client_ip}
		header_down -X-Cache-Status
	}
}

api.spectralcodex.com {
	import spectralcodex-tls
	handle /robots.txt {
		respond "User-agent: *
Disallow: /"
	}
	respond "API coming soon!" 503
}
