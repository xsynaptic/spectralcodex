# Deployment Configuration

# Connection
DEPLOY_REMOTE_HOST=deploy@your-server.com
DEPLOY_SSH_KEY_PATH=/path/to/ssh/key

# Remote paths
DEPLOY_REMOTE_PATH=/opt/server
DEPLOY_SITE_PATH=/var/www/spectralcodex
DEPLOY_MEDIA_PATH=/mnt/storage/spectralcodex
UMAMI_DATA_PATH=/mnt/storage/data/umami
UMAMI_BACKUP_PATH=/mnt/storage/data/backups

# Umami secrets (generate with: openssl rand -hex 32)
UMAMI_DB_PASSWORD=
UMAMI_APP_SECRET=

# Cloudflare (required): the cache warmer purges the zone, then warms the edge
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=

# Cache warmer tuning (optional; defaults to 8)
# CACHE_WARM_CONCURRENCY=8

# Cache warmer alert email, sent via JMAP over HTTPS
JMAP_SESSION_URL=
JMAP_API_TOKEN=

# From address defaults to ALERT_EMAIL_TO (self-to-self); override with ALERT_EMAIL_FROM
ALERT_EMAIL_TO=
# ALERT_EMAIL_FROM=

# Alert tuning: email a report on every run, success included
# ALERT_ALWAYS=1
# Suppresses the failure email below N failures (default 1 = any failure)
# ALERT_MIN_FAILURES=1
