proxy_cache_path /var/cache/nginx/imagor levels=1:2 keys_zone=imagor_cache:50m max_size=60g inactive=365d use_temp_path=off;

log_format cache '$remote_addr [$time_local] "$request" '
                 '$status $body_bytes_sent $upstream_cache_status '
                 '$request_time $upstream_response_time';

server {
    listen 80;
    server_name _;

    resolver 127.0.0.11 valid=10s;
    set $upstream http://image-server:8000;

    access_log /var/log/nginx/access.log cache;

    tcp_nopush on;

    open_file_cache max=10000 inactive=60s;
    open_file_cache_valid 30s;
    open_file_cache_min_uses 2;
    open_file_cache_errors on;

    add_header X-Cache-Status $upstream_cache_status;

    location = /health {
        proxy_pass $upstream/;
        proxy_cache off;
        access_log off;
    }

    location / {
        proxy_pass $upstream;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        proxy_cache imagor_cache;
        proxy_cache_valid 200 365d;
        proxy_cache_valid 404 1m;
        proxy_cache_valid 403 1m;
        proxy_cache_use_stale error timeout updating http_500 http_502 http_503 http_504;
        proxy_cache_lock on;
        proxy_cache_lock_timeout 20s;
        proxy_cache_key $uri;

        proxy_connect_timeout 10s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }
}
