---
import type { HTMLAttributes } from 'astro/types';

import type { MenuItem } from '#components/menu/menu-types.ts';

import { getMenuItemAriaLabel, isActiveMenuItem } from '#components/menu/menu-utils.ts';
import Link from '#components/parts/link.astro';
import TextMultilingual from '#components/parts/text-multilingual.astro';

interface Props extends HTMLAttributes<'ul'> {
	menuItems: Array<MenuItem>;
	depth: number;
	isFirstMenuItem?: boolean;
	ariaLabel?: string;
}

const { menuItems, depth, isFirstMenuItem = true, ariaLabel, ...props } = Astro.props;

const { pathname } = Astro.url;

const multilingualRegions = new Set(['taiwan', 'hong-kong']);

function shouldShowMultilingual({ item, depth }: { item: MenuItem; depth: number }) {
	switch (item.collection) {
		case 'regions': {
			return item.titleMultilingual && depth > 1 && multilingualRegions.has(item.ancestor ?? '');
		}
		case 'series': {
			return !!item.titleMultilingual;
		}
		case 'themes': {
			return !!item.titleMultilingual;
		}
		default: {
			return false;
		}
	}
}
---

<ul
	class:list={[
		'nav-sub-menu',
		depth === 1 ? 'nav-sub-menu-d1' : undefined,
		depth === 2 ? 'nav-sub-menu-d2' : undefined,
		depth > 2 ? 'nav-sub-menu-d3' : undefined,
		depth > 1 && !isFirstMenuItem ? 'sm:rounded-tr-md' : undefined,
	]}
	aria-label={ariaLabel}
	{...props}
>
	{
		menuItems.map((item, index) => {
			const children = item.children;
			const showMultilingual = shouldShowMultilingual({ item, depth });
			const isActive = isActiveMenuItem(item, pathname);
			const triggerClasses = ['nav-sub-link', isActive ? 'nav-active' : undefined];
			const multilingual = showMultilingual ? (
				<TextMultilingual class="nav-ml" content={item.titleMultilingual} parenthesis={true} />
			) : undefined;

			return (
				<li class="nav-sub-item">
					<div class="nav-sub-trigger">
						{item.url ? (
							<Link
								class:list={triggerClasses}
								href={item.url}
								linkColor="accent"
								{...(item.rel ? { rel: item.rel } : undefined)}
							>
								<Fragment set:html={item.title} />
								{multilingual}
							</Link>
						) : undefined}
						{!item.url && children?.length ? (
							<button type="button" class:list={['link link-accent', ...triggerClasses]}>
								<Fragment set:html={item.title} />
								{multilingual}
							</button>
						) : undefined}
						{!item.url && !children?.length ? (
							<span class:list={triggerClasses}>
								<Fragment set:html={item.title} />
								{multilingual}
							</span>
						) : undefined}
						{children?.length ? (
							<svg
								class="nav-sub-icon"
								width="24"
								height="24"
								viewBox="0 0 24 24"
								aria-hidden="true"
							>
								<use href="#icon:chevron-right" />
							</svg>
						) : undefined}
					</div>
					{children?.length ? (
						<Astro.self
							menuItems={children}
							depth={depth + 1}
							isFirstMenuItem={isFirstMenuItem && index === 0}
							ariaLabel={getMenuItemAriaLabel(item)}
						/>
					) : undefined}
				</li>
			);
		})
	}
</ul>
