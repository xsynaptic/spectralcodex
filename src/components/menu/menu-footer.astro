---
import type { HTMLAttributes } from 'astro/types';

import { menuFooterItems } from '#components/menu/menu-footer.ts';
import { isActiveMenuItem } from '#components/menu/menu-utils.ts';
import Link from '#components/parts/link.astro';
import { getTranslations } from '#lib/i18n/i18n-translations.ts';

type Props = HTMLAttributes<'nav'>;

const props = Astro.props;

const { pathname } = Astro.url;

const t = getTranslations();
---

<nav class="pb-4 text-sm" aria-label={t('site.menu.footer.label')} data-nosnippet {...props}>
	<ul class="flex flex-wrap gap-x-4 gap-y-2">
		{
			menuFooterItems.map((item) => (
				<li class="text-xs font-medium sm:text-sm">
					<Link
						linkColor="primary"
						class:list={[isActiveMenuItem(item, pathname) ? 'l-active' : undefined]}
						href={item.url}
						{...(item.rel ? { rel: item.rel } : undefined)}
					>
						{item.title}
					</Link>
				</li>
			))
		}
	</ul>
</nav>
