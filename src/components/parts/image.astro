---
import type { ImagorOperations } from '@xsynaptic/unpic-imagor';

import { Image as UnpicImage } from '@unpic/astro/base';
import { IMAGE_SERVER_SECRET, IMAGE_SERVER_URL } from 'astro:env/server';

import type { ImageComponentProps } from '#lib/image/image-types.ts';

import { IMAGE_LQ_FORMAT, IMAGE_LQ_QUALITY } from '#constants.ts';
import { createSignedImagePathFunction } from '#lib/image/image-server.ts';

type Props = ImageComponentProps;

const {
	class: className,
	imageQuality = IMAGE_LQ_QUALITY,
	imageFormat = IMAGE_LQ_FORMAT,
	...props
} = Astro.props;

const getSignedImagePath = createSignedImagePathFunction({
	imageQuality,
	imageFormat,
	serverSecret: IMAGE_SERVER_SECRET,
});

function transformer(src: string | URL, operations: ImagorOperations) {
	return `${IMAGE_SERVER_URL}${getSignedImagePath(src, operations)}`;
}
---

<UnpicImage
	{...props}
	class:list={['i-image', 'w-full object-cover', className]}
	transformer={transformer}
/>
