---
import type { HTMLTag, Polymorphic } from 'astro/types';

import type { MultilingualContent } from '#lib/i18n/i18n-types.ts';

import TextParenthesis from '#components/parts/text-parenthesis.astro';
import { isCjkLanguage } from '#lib/i18n/i18n-utils.ts';

type Props<Tag extends HTMLTag = HTMLTag> = Polymorphic<{
	as: Tag;
	class?: string | undefined;
	content?: MultilingualContent | undefined;
	additional?: Array<MultilingualContent> | undefined;
	parenthesis?: boolean | undefined;
}>;

const {
	as: Tag = 'span',
	class: className,
	content,
	additional,
	parenthesis = false,
	...props
} = Astro.props;
---

{
	content && parenthesis ? (
		<TextParenthesis as={Tag} class={className}>
			<Tag
				lang={content.lang}
				class:list={[isCjkLanguage(content.lang) ? 'cjk' : undefined]}
				{...props}
				set:html={content.value.trim()}
			/>
		</TextParenthesis>
	) : undefined
}
{
	content && !parenthesis ? (
		<>
			<Tag
				lang={content.lang}
				class:list={[className, isCjkLanguage(content.lang) ? 'cjk' : undefined]}
				{...props}
				set:html={content.value.trim()}
			/>
			{additional?.map((item) => (
				<>
					{'／'}
					<Tag
						lang={item.lang}
						class:list={[className, isCjkLanguage(item.lang) ? 'cjk' : undefined]}
						{...props}
						set:html={item.value.trim()}
					/>
				</>
			))}
		</>
	) : undefined
}
