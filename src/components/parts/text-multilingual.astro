---
import type { HTMLTag, Polymorphic } from 'astro/types';

import TextParenthesis from '#components/parts/text-parenthesis.astro';
import { type MultilingualContent, LanguageCodeEnum } from '#lib/i18n/i18n-types.ts';

type Props<Tag extends HTMLTag = HTMLTag> = Polymorphic<{
	as: Tag;
	class?: string | undefined;
	content?: MultilingualContent | undefined;
	additional?: Array<MultilingualContent> | undefined;
	parenthesis?: boolean | undefined;
}>;

const {
	as: Tag = 'span',
	class: className,
	content,
	additional,
	parenthesis = false,
	...props
} = Astro.props;

function isCjk(lang: string): boolean {
	return (
		lang === LanguageCodeEnum.ChineseTraditional ||
		lang === LanguageCodeEnum.ChineseSimplified ||
		lang === LanguageCodeEnum.Japanese ||
		lang === LanguageCodeEnum.Korean
	);
}
---

{
	content ? (
		<>
			{parenthesis ? (
				<TextParenthesis as={Tag} class={className}>
					<Tag
						lang={content.lang}
						class:list={[isCjk(content.lang) ? 'cjk' : undefined]}
						{...props}
					>
						<Fragment set:html={content.value} />
					</Tag>
				</TextParenthesis>
			) : (
				<>
					<Tag
						lang={content.lang}
						class:list={[className, isCjk(content.lang) ? 'cjk' : undefined]}
						{...props}
					>
						<Fragment set:html={content.value} />
					</Tag>
					{additional?.map((item) => (
						<>
							{'／'}
							<Tag
								lang={item.lang}
								class:list={[className, isCjk(item.lang) ? 'cjk' : undefined]}
								{...props}
							>
								<Fragment set:html={item.value} />
							</Tag>
						</>
					))}
				</>
			)}
		</>
	) : undefined
}
