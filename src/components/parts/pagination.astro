---
import type { Page } from 'astro';
import type { HTMLAttributes } from 'astro/types';

import * as R from 'remeda';

import Link from '#components/parts/link.astro';
import { getTranslations } from '#lib/i18n/i18n-translations.ts';
import { joinUrl, getSiteUrl } from '#lib/utils/routing.ts';
import { formatStringTemplate } from '#lib/utils/text.ts';

interface Props extends HTMLAttributes<'nav'> {
	page: Page;
}

const { class: className, page, ...props } = Astro.props;

type PaginationItem =
	| { type: 'page'; pageNumber: number; isCollapsible: boolean }
	| { type: 'current'; pageNumber: number }
	| { type: 'divider' };

interface PaginationData {
	getPageNumberLink: (pageNumber: number) => string;
	pagePrevLink: string | undefined;
	pageNextLink: string | undefined;
	pageArray: Array<PaginationItem>;
}

/**
 * This function adapted from a comment found on this popular gist
 * Note: `-1` values represent divider positions
 * @link https://gist.github.com/kottenator/9d936eb3e4e3c3e02598?permalink_comment_id=4215826#gistcomment-4215826
 */
function getPageNumberArray({
	currentPage,
	pageCount,
	pagesShown,
	minimumPagesShown = 5,
}: {
	currentPage: number;
	pageCount: number;
	pagesShown: number;
	minimumPagesShown?: number;
}) {
	let delta: number;

	const centerPagesShown = pagesShown - 5;
	const boundaryPagesShown = pagesShown - 3;

	const clampedCurrentPage = R.clamp(currentPage, { min: 1, max: pageCount });
	const clampedPagesShown = R.clamp(pagesShown, { min: minimumPagesShown, max: pageCount });

	if (pageCount <= clampedPagesShown) {
		delta = clampedPagesShown;
	} else {
		delta =
			clampedCurrentPage < boundaryPagesShown || clampedCurrentPage > pageCount - boundaryPagesShown
				? boundaryPagesShown
				: centerPagesShown;
	}

	const range = {
		start: Math.round(clampedCurrentPage - delta / 2),
		end: Math.round(clampedCurrentPage + delta / 2),
	};

	if (range.start - 1 === 1 || range.end + 1 === pageCount) {
		range.start += 1;
		range.end += 1;
	}

	let pages =
		clampedCurrentPage > delta
			? R.range(Math.min(range.start, pageCount - delta), Math.min(range.end, pageCount) + 1)
			: R.range(1, Math.min(pageCount, delta + 1) + 1);

	if (clampedCurrentPage > pageCount - boundaryPagesShown && pageCount > clampedPagesShown) {
		pages = R.range(pageCount - delta, pageCount + 1);
	}

	const withDots = (value: number, pair: Array<number>) =>
		pages.length + 1 === pageCount ? [value] : pair;

	const lastPage = pages.at(-1);

	if (pages.at(0) !== 1) {
		pages = [...withDots(1, [1, -1]), ...pages];
	}

	if (lastPage && lastPage < pageCount) {
		pages = [...pages, ...withDots(pageCount, [-1, pageCount])];
	}

	return pages;
}

function getPaginationData({
	page,
	pageCountMax = 12,
}: {
	page: Page;
	pageCountMax?: number;
}): PaginationData {
	const { currentPage, lastPage: pageCount, url } = page;

	// Remove the page number (and only the page number) from the end of the current URL
	const pageBasePath = getSiteUrl(url.current.replace(new RegExp(`/${String(currentPage)}$`), ''));

	// Get the URL for a given page
	const getPageNumberLink = (pageNumber: number) =>
		pageNumber === 1 ? pageBasePath : joinUrl(pageBasePath, String(pageNumber), '/');

	// Generate a list of page numbers, with special handling for large numbers of pages
	const rawPages =
		pageCount <= pageCountMax
			? R.range(1, pageCount + 1)
			: getPageNumberArray({ currentPage, pageCount, pagesShown: pageCountMax });

	// Transform raw numbers into a discriminated union, pre-computing collapsible state
	let isCollapsible = false;

	const pageArray: Array<PaginationItem> = rawPages.map((pageNumber) => {
		if (pageNumber === -1) {
			isCollapsible = !isCollapsible;

			return { type: 'divider' };
		}

		if (pageNumber === currentPage) {
			return { type: 'current', pageNumber };
		}

		const isAdjacentToCurrent = pageNumber === currentPage - 1 || pageNumber === currentPage + 1;

		return { type: 'page', pageNumber, isCollapsible: isCollapsible && !isAdjacentToCurrent };
	});

	return {
		getPageNumberLink,
		pagePrevLink: url.prev ?? undefined,
		pageNextLink: url.next ?? undefined,
		pageArray,
	};
}

const { getPageNumberLink, pagePrevLink, pageNextLink, pageArray } = getPaginationData({ page });

const t = getTranslations();

function getPageNumberAriaLabel(pageNumber: number) {
	return formatStringTemplate(t('site.pagination.pageNumber.label'), { page: pageNumber });
}
---

{
	pagePrevLink || pageNextLink ? (
		<nav class:list={[className]} aria-label={t('site.pagination.label')} {...props}>
			<ul
				class:list={[
					'flex flex-wrap gap-4 text-base font-medium tabular-nums select-none md:gap-1 md:text-sm',
					page.lastPage >= 10 ? 'justify-between' : undefined,
				]}
			>
				{pagePrevLink ? (
					<li class="flex flex-wrap gap-1 pr-2">
						<span class:list={['select-none', 'text-accent-300 dark:text-accent-400']}>
							&lsaquo;
						</span>
						<Link href={pagePrevLink} aria-label={t('pagination.previous')}>
							{t('pagination.previous')}
						</Link>
					</li>
				) : undefined}
				{pageArray.map((item) => {
					switch (item.type) {
						case 'divider': {
							return (
								<li class="text-primary-300 dark:text-primary-600" aria-hidden="true">
									&#x22EF;
								</li>
							);
						}
						case 'current': {
							return (
								<li class="px-2 font-bold first:pl-0 last:pr-0" aria-current="page">
									{String(item.pageNumber)}
								</li>
							);
						}
						case 'page': {
							return (
								<li
									class:list={[
										'first:-ml-2 last:-mr-2',
										item.isCollapsible ? 'hidden md:block' : undefined,
									]}
								>
									<Link
										href={getPageNumberLink(item.pageNumber)}
										class="px-2"
										aria-label={getPageNumberAriaLabel(item.pageNumber)}
									>
										{String(item.pageNumber)}
									</Link>
								</li>
							);
						}
					}
				})}
				{pageNextLink ? (
					<li class="flex flex-wrap gap-1 pl-2">
						<Link href={pageNextLink} aria-label={t('pagination.next')}>
							{t('pagination.next')}
						</Link>
						<span class:list={['select-none', 'text-accent-300 dark:text-accent-500']}>
							&rsaquo;
						</span>
					</li>
				) : undefined}
			</ul>
		</nav>
	) : undefined
}
