---
import type { HTMLTag, Polymorphic } from 'astro/types';

type Props<Tag extends HTMLTag = HTMLTag> = Polymorphic<{
	as: Tag;
	class?: string | undefined;
	fillViewport?: boolean | undefined;
}>;

const { as: Tag = 'div', class: className, fillViewport, ...props } = Astro.props;
---

<Tag
	class:list={[
		fillViewport ? 'mx-auto max-w-content sm:px-4 md:px-8' : 'mx-auto max-w-content px-4 md:px-8',
		className,
	]}
	{...props}
>
	<slot />
</Tag>
