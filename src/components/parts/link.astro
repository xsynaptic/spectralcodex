---
import type { HTMLAttributes } from 'astro/types';

import { renderSlot } from '#lib/utils/astro.ts';

const LinkColorEnum = {
	Primary: 'primary',
	PrimaryBright: 'primary-bright',
	Highlight: 'highlight',
	Accent: 'accent',
} as const;

type LinkColor = (typeof LinkColorEnum)[keyof typeof LinkColorEnum];

interface Props extends HTMLAttributes<'a'> {
	linkColor?: LinkColor | undefined;
	isActive?: boolean | undefined;
	showDarkMode?: boolean | undefined;
}

const {
	class: className,
	href,
	linkColor = LinkColorEnum.Accent,
	isActive = false,
	showDarkMode = true,
	...props
} = Astro.props;

const children = await renderSlot(Astro.slots, 'default');
---

<a
	href={href}
	class:list={[
		'link',
		`link-${linkColor}`,
		isActive ? 'link-active' : undefined,
		showDarkMode ? undefined : 'link-static',
		className,
	]}
	{...props}><Fragment set:html={children} /></a
>
