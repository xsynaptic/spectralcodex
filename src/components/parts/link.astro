---
import type { HTMLAttributes } from 'astro/types';

import { renderSlot } from '#lib/utils/astro.ts';

type LinkColor = 'accent' | 'highlight' | 'primary' | 'primary-bright';

interface Props extends HTMLAttributes<'a'> {
	linkColor?: LinkColor | undefined;
	isActive?: boolean | undefined;
	showDarkMode?: boolean | undefined;
}

const {
	class: className,
	href,
	linkColor = 'accent',
	isActive = false,
	showDarkMode = true,
	...props
} = Astro.props;

const children = await renderSlot(Astro.slots, 'default');
---

<a
	href={href}
	class:list={[
		'link',
		`link-${linkColor}`,
		isActive ? 'link-active' : undefined,
		showDarkMode ? undefined : 'link-static',
		className,
	]}
	{...props}><Fragment set:html={children} /></a
>
