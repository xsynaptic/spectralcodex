---
import type { HTMLAttributes } from 'astro/types';

import type { ImageContext, ImageLayout } from '#lib/image/image-types.ts';

import ContentImage from '#components/content/content-image.astro';

interface Props extends HTMLAttributes<'figure'> {
	src: string;
	alt?: string;
	layout?: ImageLayout;
	context?: ImageContext;
	showMetadata?: boolean;
}

const { src: imageId, showMetadata = true, ...props } = Astro.props;
---

{
	imageId ? (
		<ContentImage imageId={imageId} showMetadata={showMetadata} {...props}>
			<slot />
		</ContentImage>
	) : undefined
}
