---
import type { HTMLAttributes } from 'astro/types';
import type { CollectionEntry } from 'astro:content';

import ImageMetadataItem from '#components/image/image-metadata-item.astro';
import DateDisplay from '#components/parts/date-display.astro';
import { getTranslations } from '#lib/i18n/i18n-translations.ts';
import { DatePresetEnum } from '#lib/utils/date.ts';

interface Props extends HTMLAttributes<'div'> {
	entry: CollectionEntry<'images'>;
}

const { entry, ...props } = Astro.props;

const t = getTranslations();
---

<div class:list={['absolute inset-0 overflow-hidden']} data-pagefind-ignore {...props}>
	<button
		class:list={[
			'group peer opacity-80 transition-opacity delay-200 duration-300 focus:opacity-100 sm:opacity-0 sm:hover:opacity-100',
		]}
		aria-label={t('collection.images.metadata.title')}
	>
		<span
			class:list={[
				'text-primary-50 dark:text-primary-50',
				'absolute right-0 bottom-0 z-10 cursor-pointer p-2 transition-opacity delay-500 duration-200 group-focus-within:pointer-events-none group-focus-within:opacity-0 group-focus-within:delay-100',
			]}
		>
			<svg width="24" height="24" viewBox="0 0 24 24" class="drop-shadow-md" aria-hidden="true">
				<use href="#icon:eye-open"></use>
			</svg>
		</span>
		<span
			class:list={[
				'pointer-events-none absolute inset-0 flex h-full max-h-full w-full translate-x-full items-end overflow-y-auto font-sans opacity-0 transition-[opacity,translate] delay-[100ms,300ms] duration-[200ms,0ms] group-focus-within:pointer-events-auto group-focus-within:translate-x-0 group-focus-within:opacity-100 group-focus-within:delay-[100ms,0ms] sm:rounded-b-xs',
			]}
		>
			<span
				class:list={[
					'bg-primary-50/75 dark:bg-primary-800/75',
					'grid max-h-full w-full grid-cols-4 gap-1 overflow-y-auto px-small py-2 backdrop-grayscale sm:grid-cols-8 sm:gap-2 md:grid-cols-12 md:gap-4 @max-lg:sm:gap-1 @max-lg:md:grid-cols-8 @max-sm:sm:grid-cols-4 @max-sm:md:grid-cols-4',
				]}
			>
				<ImageMetadataItem class="col-span-4">
					<Fragment slot="image-metadata-item-title">
						{t('collection.images.metadata.dateCreated.label')}
					</Fragment>
					{
						entry.data.dateCreated ? (
							<DateDisplay date={entry.data.dateCreated} datePreset={DatePresetEnum.Long} />
						) : undefined
					}
				</ImageMetadataItem>
				<ImageMetadataItem class="col-span-4">
					<Fragment slot="image-metadata-item-title">
						{t('collection.images.metadata.cameraModel.label')}
					</Fragment>
					{entry.data.camera}
				</ImageMetadataItem>
				<ImageMetadataItem class="col-span-4">
					<Fragment slot="image-metadata-item-title">
						{t('collection.images.metadata.lensModel.label')}
					</Fragment>
					{entry.data.lens}
				</ImageMetadataItem>
				<ImageMetadataItem class="col-span-2">
					<Fragment slot="image-metadata-item-title">
						{t('collection.images.metadata.aperture.label')}
					</Fragment>
					{
						entry.data.aperture ? (
							<>
								<em>&#402;</em>&#8202;/&#8202;{entry.data.aperture}
							</>
						) : undefined
					}
				</ImageMetadataItem>
				<ImageMetadataItem class="col-span-2">
					<Fragment slot="image-metadata-item-title">
						{t('collection.images.metadata.shutterSpeed.label')}
					</Fragment>
					{entry.data.shutterSpeed ? `${entry.data.shutterSpeed} sec` : undefined}
				</ImageMetadataItem>
				<ImageMetadataItem class="col-span-2">
					<Fragment slot="image-metadata-item-title">
						{t('collection.images.metadata.focalLength.label')}
					</Fragment>
					{entry.data.focalLength}
				</ImageMetadataItem>
				<ImageMetadataItem class="col-span-2">
					<Fragment slot="image-metadata-item-title">
						{t('collection.images.metadata.iso.label')}
					</Fragment>
					{entry.data.iso}
				</ImageMetadataItem>
				<ImageMetadataItem class="col-span-2">
					<Fragment slot="image-metadata-item-title">
						{t('collection.images.metadata.exposureValue.label')}
					</Fragment>
					{
						entry.data.exposureValue ? (
							<>
								{Number(entry.data.exposureValue).toFixed(1)}&nbsp;
								{t('collection.images.metadata.ev.label')}
							</>
						) : undefined
					}
				</ImageMetadataItem>
				<ImageMetadataItem class="col-span-2">
					<Fragment slot="image-metadata-item-title"
						>{t('collection.images.metadata.sourceDimensions.label')}</Fragment
					>
					<Fragment
						set:html={`${String(entry.data.width)}&#8202;&#215;&#8202;${String(entry.data.height)}`}
					/>
				</ImageMetadataItem>
			</span>
		</span>
	</button>
	<button
		class:list={[
			'pointer-events-none opacity-0 transition-opacity duration-100 peer-focus-within:pointer-events-auto peer-focus-within:opacity-100',
		]}
		aria-label={t('collection.images.metadata.close.title')}
		><span
			class:list={[
				'text-accent-700 dark:text-accent-400',
				'absolute right-0 bottom-0 z-20 cursor-pointer p-2',
			]}
		>
			<svg width="24" height="24" viewBox="0 0 24 24" class="drop-shadow-md" aria-hidden="true">
				<use href="#icon:eye-closed"></use>
			</svg>
		</span></button
	>
</div>
