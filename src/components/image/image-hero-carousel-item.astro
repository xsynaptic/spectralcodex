---
import type { ImageComponentProps, ImagePlaceholderProps } from '#lib/image/image-types.ts';
import type { ImageFeaturedWithCaption } from '#lib/metadata/metadata-types.ts';

import ImageCarouselCaption from '#components/image/image-carousel-caption.astro';
import ImagePlaceholder from '#components/image/image-placeholder.astro';
import Image from '#components/parts/image.astro';
import { IMAGE_HERO_FORMAT, IMAGE_HERO_QUALITY } from '#constants.ts';
import { getImageByIdFunction } from '#lib/collections/images/images-utils.ts';
import { getImageBreakpoints } from '#lib/image/image-layout.ts';
import { ImageSizeEnum } from '#lib/image/image-types.ts';
import { ImageFitOptionEnum } from '#lib/image/image-types.ts';
import { sanitizeImageAltAttribute } from '#lib/utils/text.ts';
import { zIndexScaleEnum } from '#lib/utils/z-index.ts';

interface Props extends ImageFeaturedWithCaption {
	class?: string | undefined;
	index: number;
	fallbackAlt?: string | undefined;
	withTitle?: boolean | undefined;
}

const {
	class: className,
	index,
	id: imageId,
	title,
	captionMetadata,
	fallbackAlt,
	withTitle = false,
} = Astro.props;

async function getImageProps(
	imageId: string | undefined,
	alt: string,
	priority: boolean,
): Promise<{
	imageProps: ImageComponentProps | undefined;
	placeholderProps: ImagePlaceholderProps | undefined;
}> {
	const getImageById = await getImageByIdFunction();

	const imageEntry = getImageById(imageId);

	if (!imageId || !imageEntry) return { imageProps: undefined, placeholderProps: undefined };

	const aspectRatio = 3 / 2;
	const fit = ImageFitOptionEnum.Cover;

	return {
		imageProps: {
			src: imageId,
			breakpoints: getImageBreakpoints({ maxWidth: imageEntry.data.width }),
			sizes: '100vw',
			width: ImageSizeEnum.ExtraExtraLarge,
			height: Math.round(ImageSizeEnum.ExtraExtraLarge / aspectRatio),
			alt: sanitizeImageAltAttribute(alt),
			unstyled: true,
			operations: { fit },
			imageQuality: IMAGE_HERO_QUALITY,
			imageFormat: IMAGE_HERO_FORMAT,
			...(priority ? { priority: true } : {}),
		} satisfies ImageComponentProps,
		placeholderProps: {
			imageId,
			aspectRatio,
			fit,
			highQuality: priority,
		},
	};
}

const { imageProps, placeholderProps } = await getImageProps(
	imageId,
	title ?? fallbackAlt ?? '',
	index === 0,
);
---

{
	imageProps ? (
		<ImagePlaceholder class:list={['relative', className]} placeholderProps={placeholderProps}>
			<Image
				class:list={[
					'max-h-screen min-h-[400px] w-full text-sm text-transparent xl:min-h-screen',
					'aspect-3/2 sm:aspect-5/4 md:aspect-3/2 lg:aspect-video xl:aspect-auto',
				]}
				style={{ zIndex: zIndexScaleEnum.ImageBase }}
				{...imageProps}
			/>
			{captionMetadata ? (
				<ImageCarouselCaption
					captionMetadata={captionMetadata}
					isHero={true}
					withTitle={withTitle}
				/>
			) : undefined}
		</ImagePlaceholder>
	) : undefined
}
