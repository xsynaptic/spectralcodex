---
import type { HTMLAttributes } from 'astro/types';

import { wrapCjk } from '@xsynaptic/unified-tools';

import { getTranslations } from '#lib/i18n/i18n-translations.ts';

interface Props extends HTMLAttributes<'address'> {
	address?: string | undefined;
	class?: string | undefined;
}

const { address, class: className, ...props } = Astro.props;

const output = address ? wrapCjk({ input: address }) : undefined;

const t = getTranslations();
---

{
	output ? (
		<address
			class:list={[className, 'mt-1 px-4 text-xs font-normal text-primary-400 sm:px-0']}
			{...props}
		>
			{t('locations.address.label')}: <span set:html={output} />
		</address>
	) : undefined
}
