---
import { Font } from 'astro:assets';
import { WEBMENTION_DOMAIN } from 'astro:env/client';

import '#styles/main.css';
import { IPX_SERVER_URL } from 'astro:env/server';
import { ClientRouter } from 'astro:transitions';

import type { MetaProps } from '#components/types.ts';
import type { Thing } from '#lib/utils/seo-structured-data.ts';

import Analytics from '#components/main/main-analytics.astro';
import Colophon from '#components/main/main-colophon.astro';
import Meta from '#components/main/main-meta.astro';
import SkipLink from '#components/main/main-skip-link.astro';
import Sprites from '#components/main/main-sprites.astro';
import Stylesheet from '#components/main/main-stylesheet.astro';
import MenuFooter from '#components/menu/menu-footer.astro';
import MenuHeader from '#components/menu/menu-header.astro';
import ModeManager from '#components/mode-manager/mode-manager.astro';
import ModeToggle from '#components/mode-manager/mode-toggle.astro';
import Container from '#components/parts/container.astro';
import Link from '#components/parts/link.astro';
import ProgressLoading from '#components/progress/progress-loading.astro';
import ProgressReading from '#components/progress/progress-reading.astro';
import Search from '#components/search/search.astro';
import { getTranslations } from '#lib/i18n/i18n-translations.ts';
import { getSiteUrl } from '#lib/utils/routing.ts';
import { serializeGraph } from '#lib/utils/seo-structured-data.ts';

interface Props {
	meta?: MetaProps;
	schemas?: Array<Thing>;
	hasHeroImage?: boolean;
	isHomepage?: boolean;
}

const { hasHeroImage = false, meta, schemas, isHomepage = false } = Astro.props;

const siteUrl = getSiteUrl();

const t = getTranslations();
---

<!doctype html>
<html lang={Astro.currentLocale}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width,initial-scale=1" />
		<link
			rel="icon"
			type="image/svg+xml"
			href={`${getSiteUrl()}favicon.svg`}
			media="(prefers-color-scheme: light)"
		/>
		<link
			rel="icon"
			type="image/svg+xml"
			href={`${getSiteUrl()}favicon.svg`}
			media="(prefers-color-scheme: dark)"
		/>
		<link rel="preconnect" href={IPX_SERVER_URL} crossorigin />
		<Stylesheet />
		<Font cssVariable="--font-commissioner" preload={[{ subset: 'latin' }]} />
		<Font cssVariable="--font-geologica" preload={[{ subset: 'latin' }]} />
		<Font cssVariable="--font-lora" preload={[{ subset: 'latin', style: 'normal' }]} />
		<ModeManager defaultMode="auto" />
		<Meta {...meta} />
		<Analytics isViewTransitionsEnabled={true} />
		<ClientRouter />
		<link
			rel="alternate"
			type="application/rss+xml"
			title={t('site.title')}
			href={`${getSiteUrl()}rss.xml`}
		/>
		<link rel="sitemap" href={`${getSiteUrl()}sitemap-index.xml`} />
		{
			WEBMENTION_DOMAIN ? (
				<link rel="webmention" href={`https://webmention.io/${WEBMENTION_DOMAIN}/webmention`} />
			) : undefined
		}
	</head>
	<body
		class:list={[
			'bg-primary-100 text-primary-700 dark:bg-primary-800 dark:text-primary-400',
			'visible flex min-h-screen min-w-[350px] flex-col overflow-visible overscroll-contain transition-colors',
		]}
	>
		<Sprites />
		<ProgressLoading
			class:list={[
				'rounded-br-md shadow-lg shadow-current',
				'bg-linear-to-r from-highlight-400 to-highlight-300 text-highlight-200 dark:text-highlight-800',
			]}
			height="2.5px"
			style={{ zIndex: '99' }}
		/>
		<ProgressReading
			class:list={[
				'rounded-br-md shadow-lg shadow-current',
				'bg-linear-to-r from-accent-500 to-accent-300 text-accent-200 dark:text-accent-800',
			]}
			height="2.5px"
			style={{ zIndex: 98 }}
		/>
		<header
			class:list={[
				'transition-colors',
				hasHeroImage
					? 'bg-header-fade sm:absolute sm:top-0 sm:right-0 sm:left-0'
					: 'bg-primary-100 dark:bg-primary-800',
			]}
			style={{ zIndex: 40 }}
		>
			<SkipLink
				class:list={[
					'rounded-br-sm px-4 py-1 uppercase transition-colors',
					'bg-primary-50 text-accent-500 hover:text-accent-400 dark:bg-primary-800 dark:text-accent-400 dark:hover:text-accent-300',
				]}
				target="#main-content"
				label={t('site.skip.label')}
			/>
			<Container
				as="div"
				class="flex flex-wrap items-center justify-between gap-x-2 gap-y-2 pt-2 sm:pb-1"
				>{
					isHomepage ? (
						<h1 class="flex grow items-center gap-1">
							<Link
								href={siteUrl}
								class="text-xl font-semibold md:text-2xl lg:text-3xl"
								linkColor="primary"
							>
								{t('site.title')}
							</Link>
						</h1>
					) : (
						<h2 class="flex grow items-center gap-1">
							<Link
								href={siteUrl}
								class="text-xl font-semibold md:text-2xl lg:text-3xl"
								linkColor="primary"
							>
								{t('site.title')}
							</Link>
						</h2>
					)
				}
				<ModeToggle />
				<Search />
			</Container>
			<Container class="w-full overflow-x-clip" fillViewport={true}>
				<MenuHeader hasHeroImage={hasHeroImage} />
			</Container>
		</header>
		<main class="flex-1" {...hasHeroImage ? {} : { id: 'main-content' }}>
			<slot />
		</main>
		<Container as="footer" class="mt-8 mb-8 w-full pt-4">
			<div
				class:list={[
					'border-t pt-4 pb-8',
					'border-primary-200 text-primary-400 dark:border-primary-700 dark:text-primary-700',
				]}
			>
				<MenuFooter />
				<Colophon />
			</div>
		</Container>
		{
			schemas && schemas.length > 0 ? (
				<script type="application/ld+json" is:inline set:html={serializeGraph(schemas)} />
			) : undefined
		}
	</body>
</html>
