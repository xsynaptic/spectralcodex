---
import type { HTMLAttributes } from 'astro/types';

import { UMAMI_DOMAIN, UMAMI_ID } from 'astro:env/client';

interface Props extends HTMLAttributes<'script'> {
	isViewTransitionsEnabled: boolean;
}

const { isViewTransitionsEnabled, ...props } = Astro.props;
---

{
	import.meta.env.PROD && UMAMI_ID && UMAMI_DOMAIN ? (
		<script
			defer
			src={`${UMAMI_DOMAIN}/script.js`}
			data-website-id={UMAMI_ID}
			data-performance={true}
			{...props}
			{...(isViewTransitionsEnabled ? { 'data-astro-rerun': '' } : {})}
			is:inline
		/>
	) : undefined
}
