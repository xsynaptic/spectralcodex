---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'script'> {
	umamiDomain: string;
	umamiId: string;
	isViewTransitionsEnabled: boolean;
}

const { umamiDomain, umamiId, isViewTransitionsEnabled, ...props } = Astro.props;
---

<script
	src={`${umamiDomain}/script.js`}
	data-website-id={umamiId}
	data-performance={true}
	data-exclude-hash={true}
	data-do-not-track={true}
	{...props}
	{...isViewTransitionsEnabled ? { 'data-astro-rerun': '' } : {}}
	defer
	is:inline></script>
