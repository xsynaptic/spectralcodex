---
interface Props {
	class?: string | undefined;
	height?: string | undefined;
}

const { class: className, height = '1px', ...props } = Astro.props;
---

<progress-loading class:list={[className]} style={{ height }} transition:persist {...props}
></progress-loading>

<script>
	import '#lib/components/progress-loading.ts';
</script>
