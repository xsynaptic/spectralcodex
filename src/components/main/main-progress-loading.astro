---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'div'> {
	height?: string | undefined;
}

const { class: className, height = '1px', style = {}, ...props } = Astro.props;
---

<progress-loading class={className} style={{ height, ...style }} transition:persist {...props}
></progress-loading>

<script>
	import '#lib/components/progress-loading.ts';
</script>
