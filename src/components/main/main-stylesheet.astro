---
/**
 * We use this to hide the body until the page is loaded to prevent a flash of unstyled content
 * It is a brute force method but seems effective enough for our purposes
 * Note: the background colors match Tailwind colors applied to the body element
 */
---

<style is:inline>
	@layer base {
		:root {
			--color-body-bg: oklch(96.7% 0.001 286.375deg);
		}

		[data-mode='dark'] {
			--color-body-bg: oklch(27.4% 0.006 286.033deg);
		}

		body {
			visibility: hidden;
			overflow: hidden;
			background-color: var(--color-body-bg);
		}
	}
</style>
