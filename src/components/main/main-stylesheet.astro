---
/**
 * We use this to hide the body until the page is loaded to prevent a flash of unstyled content
 * It is a brute force method but seems effective enough for our purposes
 * Note 1: the background colors match Tailwind colors applied to the body element
 * Note 2: these custom properties are also consumed by the mode-manager; use hex/rgb/hsl, not oklch!
 */
---

<style is:inline>
	@layer base {
		:root {
			--color-body-bg: #f4f4f5;
		}

		[data-mode='dark'] {
			--color-body-bg: #27272a;
		}

		body {
			visibility: hidden;
			overflow: hidden;
			background-color: var(--color-body-bg);
		}
	}
</style>
