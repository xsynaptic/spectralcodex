---
import type { HTMLAttributes } from 'astro/types';

/**
 * Adapted from the Accessible Astro Components library
 * @link https://github.com/incluud/accessible-astro-components
 */
interface Props extends HTMLAttributes<'div'> {
	parentClass?: string | undefined;
	target?: string | undefined;
	label: string;
}

const { class: className, parentClass, target = '#main-content', label, ...props } = Astro.props;
---

<div class:list={['skip-link', parentClass]} {...props}>
	<a
		href={target}
		class:list={[
			'absolute hover:outline-2 hover:outline-current focus-visible:outline-2 focus-visible:outline-current',
			className,
		]}>{label}</a
	>
</div>

<style>
	:where(.skip-link a) {
		inset-inline-start: 0;
		translate: 0 -100vh;
		transition: translate 0.2s ease-in-out;
	}

	:where(.skip-link a:hover),
	:where(.skip-link a:focus-visible) {
		translate: 0 0;
	}
</style>
