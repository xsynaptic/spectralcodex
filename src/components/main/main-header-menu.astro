---
import type { HTMLAttributes } from 'astro/types';

import MenuHeaderSubmenu from '#components/main/main-header-menu-submenu.astro';
import Link from '#components/parts/link.astro';
import { getTranslations } from '#lib/i18n/i18n-translations.ts';
import { getMenuHeaderItems } from '#lib/main/main-menu-header.ts';
import { getMenuItemAriaLabel, isActiveMenuItem } from '#lib/main/main-menu-utils.ts';

interface Props extends HTMLAttributes<'nav'> {
	hasHeroImage: boolean;
}

const { hasHeroImage, ...props } = Astro.props;

const { pathname } = Astro.url;

const menuItems = await getMenuHeaderItems();

const t = getTranslations();
---

<nav-menu>
	<nav class="nav-menu" aria-label={t('site.menu.header.label')} data-nosnippet {...props}>
		<ul class:list={['nav-ul', hasHeroImage ? 'nav-hero' : 'nav-no-hero']}>
			{
				menuItems.map((item) => (
					<li class="nav-item">
						<div class="nav-item-trigger">
							<Link
								class:list={[
									'nav-item-link',
									isActiveMenuItem(item, pathname) ? 'nav-active' : undefined,
								]}
								href={item.url}
								linkColor="accent"
								{...(item.rel ? { rel: item.rel } : undefined)}
							>
								{item.title}
							</Link>
							{item.children ? (
								<svg width="24" height="24" viewBox="0 0 24 24" class="nav-icon" aria-hidden="true">
									<use href="#icon:chevron-down" />
								</svg>
							) : undefined}
						</div>
						{item.children ? (
							<MenuHeaderSubmenu
								menuItems={item.children}
								depth={1}
								ariaLabel={getMenuItemAriaLabel(item)}
							/>
						) : undefined}
					</li>
				))
			}
		</ul>
	</nav>
</nav-menu>

<script>
	import '#lib/components/nav-menu.ts';
</script>
