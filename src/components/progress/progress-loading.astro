---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'div'> {
	height?: string | undefined;
}

const { class: className, height = '1px', style = {}, ...props } = Astro.props;
---

<progress-loading
	class:list={['progress-bar', className]}
	style={{ height, ...style }}
	transition:persist
	{...props}></progress-loading>

<script>
	import '#components/progress/progress-loading.ts';
</script>
