---
import type { CatalogItem } from '#lib/catalog/catalog-types.ts';

import ContentSection from '#components/content/content-section.astro';
import PreviewList from '#components/parts/preview-list.astro';
import Prose from '#components/parts/prose.astro';
import { getTranslations } from '#lib/i18n/i18n-translations.ts';

interface Props {
	items: Array<CatalogItem>;
	count: number;
}

const { items, count, ...props } = Astro.props;

const hasItems = items.length > 0;

const t = getTranslations();
---

{
	hasItems ? (
		<ContentSection data-pagefind-ignore data-nosnippet {...props}>
			<Fragment slot="section-title">{t('section.itemsList')}</Fragment>
			<Prose>
				<PreviewList items={items} count={count} />
			</Prose>
		</ContentSection>
	) : undefined
}
