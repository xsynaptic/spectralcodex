---
import type { Page } from 'astro';

import type { PreviewOptions } from '#components/types.ts';
import type { CatalogItem } from '#lib/catalog/catalog-types.ts';

import ContentSection from '#components/content/content-section.astro';
import PaginationSelect from '#components/parts/pagination-select.astro';
import PreviewGrid from '#components/parts/preview-grid.astro';
import { getTranslations } from '#lib/i18n/i18n-translations.ts';

interface Props {
	title?: string;
	items?: Array<CatalogItem>;
	page?: Page<CatalogItem>;
	previewOptions?: PreviewOptions | undefined;
}

const { title, items, page, previewOptions, ...props } = Astro.props;

const defaultPreviewOptions: PreviewOptions = {
	showDate: true,
	showRegion: true,
	showTitleMultilingual: true,
};

const hasItems = items && items.length > 0;

const t = getTranslations();
---

{
	hasItems || page ? (
		<ContentSection data-pagefind-ignore data-nosnippet {...props}>
			<Fragment slot="section-title">{title ?? t('section.content')}</Fragment>
			{page ? (
				<>
					<PreviewGrid items={page.data} {...defaultPreviewOptions} {...previewOptions} />
					<PaginationSelect class="mt-4 md:mt-8" page={page} />
				</>
			) : undefined}
			{hasItems ? (
				<PreviewGrid items={items} {...defaultPreviewOptions} {...previewOptions} />
			) : undefined}
		</ContentSection>
	) : undefined
}
