---
import type { DateRecordedEntry } from '#lib/utils/date.ts';

import ContentSection from '#components/content/content-section.astro';
import DateDisplay from '#components/parts/date-display.astro';
import ListColumnItem from '#components/parts/list-column-item.astro';
import ListColumn from '#components/parts/list-column.astro';
import { DatePresetEnum, getDateRanges } from '#lib/utils/date.ts';

interface Props {
	dates: Array<DateRecordedEntry> | undefined;
	title: string;
}

const { dates, title, ...props } = Astro.props;

const dateRanges = dates ? getDateRanges(dates) : [];

const timeOptions = {
	hour: '2-digit',
	minute: '2-digit',
	hour12: false,
} satisfies Intl.DateTimeFormatOptions;
---

{
	dateRanges.length > 0 ? (
		<ContentSection data-pagefind-ignore {...props}>
			<Fragment slot="section-title">{title}</Fragment>
			<ListColumn class="font-serif text-xs sm:text-sm">
				{dateRanges.map((range) => (
					<ListColumnItem>
						<DateDisplay
							date={range.start.date}
							dateEnd={range.end?.date}
							datePreset={DatePresetEnum.Medium}
							dateOptions={range.start.hasTime || range.end?.hasTime ? timeOptions : undefined}
						/>
					</ListColumnItem>
				))}
			</ListColumn>
		</ContentSection>
	) : undefined
}
