---
import type { HTMLAttributes } from 'astro/types';
import type { CollectionEntry } from 'astro:content';

import type { ImageLayout } from '#lib/image/image-types.ts';
import type { ImageComponentProps, ImagePlaceholderProps } from '#lib/image/image-types.ts';

import ImageMetadata from '#components/image-metadata/image-metadata.astro';
import ImagePlaceholder from '#components/image/image-placeholder.astro';
import Image from '#components/parts/image.astro';
import { IMAGE_HQ_FORMAT, IMAGE_HQ_QUALITY } from '#constants.ts';
import { getImageByIdFunction } from '#lib/collections/images/images-utils.ts';
import {
	getImageLayoutSizesProp,
	getImageBreakpoints,
	getImageInferredWidth,
} from '#lib/image/image-layout.ts';
import { ImageLayoutEnum, ImageSizeEnum } from '#lib/image/image-types.ts';
import { renderSlot } from '#lib/utils/astro.ts';
import { sanitizeImageAltAttribute, sanitizeImageCaption } from '#lib/utils/text.ts';

interface Props extends HTMLAttributes<'figure'> {
	imageId: string;
	alt?: string;
	layout?: ImageLayout;
	priority?: boolean;
	showMetadata?: boolean;
}

const {
	imageId,
	alt: altProp,
	layout = ImageLayoutEnum.Default,
	priority = false,
	showMetadata = false,
	...props
} = Astro.props;

// This controls how the component is rendered; feeds require a less complex output
const { isFeed } = Astro.locals;

const slotContents = await renderSlot(Astro.slots, 'default');

function getAspectRatio(width: number, height: number) {
	function greatestCommonDenominator(a: number, b: number): number {
		return b === 0 ? a : greatestCommonDenominator(b, a % b);
	}

	const aspectRatioDivisor = greatestCommonDenominator(width, height);

	return `${String(width / aspectRatioDivisor)} / ${String(height / aspectRatioDivisor)}`;
}

async function getImageProps(): Promise<{
	imageEntry: CollectionEntry<'images'> | undefined;
	imageProps: ImageComponentProps | undefined;
	placeholderProps: ImagePlaceholderProps | undefined;
	aspectRatioString: string | undefined;
}> {
	const getImageById = await getImageByIdFunction();

	const imageEntry = getImageById(imageId);

	if (!imageEntry)
		return {
			imageEntry: undefined,
			imageProps: undefined,
			placeholderProps: undefined,
			aspectRatioString: undefined,
		};

	const { width } = getImageInferredWidth({
		width: imageEntry.data.width,
		height: imageEntry.data.height,
		layout,
	});
	const feedWidth =
		imageEntry.data.height > imageEntry.data.width ? ImageSizeEnum.Medium : ImageSizeEnum.Large;
	const primaryWidth = isFeed ? feedWidth : width;

	return {
		imageEntry,
		imageProps: {
			src: imageId,
			breakpoints: getImageBreakpoints({ maxWidth: imageEntry.data.width }),
			sizes: getImageLayoutSizesProp(layout, priority),
			width: primaryWidth,
			...(isFeed
				? { height: Math.round((primaryWidth * imageEntry.data.height) / imageEntry.data.width) }
				: {}),
			unstyled: true,
			imageQuality: IMAGE_HQ_QUALITY,
			imageFormat: IMAGE_HQ_FORMAT,
			...(priority ? { priority: true } : {}),
			alt: sanitizeImageAltAttribute(altProp ?? slotContents ?? imageEntry.data.title),
		},
		placeholderProps: {
			imageId,
			aspectRatio: imageEntry.data.width / imageEntry.data.height,
		},
		aspectRatioString: getAspectRatio(imageEntry.data.width, imageEntry.data.height),
	};
}

const { imageEntry, imageProps, placeholderProps, aspectRatioString } = await getImageProps();

const caption = slotContents ? sanitizeImageCaption(slotContents) : undefined;
---

{
	imageProps ? (
		isFeed ? (
			<figure {...props}>
				<Image {...imageProps} />
				{caption ? (
					<figcaption>
						<Fragment set:html={caption} />
					</figcaption>
				) : undefined}
			</figure>
		) : (
			<figure
				class:list={[
					'c-wrap c-escape',
					layout === ImageLayoutEnum.None ? undefined : `c-${layout}`,
				]}
				{...props}
			>
				<ImagePlaceholder placeholderProps={placeholderProps}>
					<Image
						{...(aspectRatioString ? { style: { aspectRatio: aspectRatioString } } : {})}
						{...imageProps}
					/>
					{showMetadata && imageEntry ? <ImageMetadata entry={imageEntry} /> : undefined}
				</ImagePlaceholder>
				{caption ? (
					<figcaption class="c-caption">
						<Fragment set:html={caption} />
					</figcaption>
				) : undefined}
			</figure>
		)
	) : undefined
}
