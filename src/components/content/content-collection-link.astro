---
import type { CatalogCollectionKey } from '#lib/catalog/catalog-types.ts';

import Link from '#components/parts/link.astro';
import { getTranslations } from '#lib/i18n/i18n-translations.ts';
import { getSiteUrl } from '#lib/utils/routing.ts';

interface Props {
	collection: CatalogCollectionKey;
}

const { collection, ...props } = Astro.props;

const collectionUrl = getSiteUrl(collection);

const t = getTranslations();
---

<Link class="font-semibold" href={collectionUrl} linkColor="highlight" {...props}
	>{t(`collection.${collection}.labelPlural`)}</Link
>
