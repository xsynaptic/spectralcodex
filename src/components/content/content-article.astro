---
import type { HTMLAttributes } from 'astro/types';

import { IPX_SERVER_SECRET, IPX_SERVER_URL } from 'astro:env/server';

import { IMAGE_FORMAT, IMAGE_QUALITY } from '#constants.ts';
import { getImageByIdFunction } from '#lib/collections/images/images-utils.ts';
import { createSignedIpxPathFunction } from '#lib/image/image-server.ts';
import { ImageFitOptionEnum } from '#lib/image/image-types.ts';

interface Props extends HTMLAttributes<'article'> {
	imageId: string | undefined;
	hideSearch?: boolean | undefined;
}

const { imageId, hideSearch, ...props } = Astro.props;

// Pagefind renders result thumbnails at 64×48 (4:3) via `--pf-image-width` / `--pf-image-height`
const SEARCH_THUMBNAIL_WIDTH = 64;
const SEARCH_THUMBNAIL_WIDTH_2X = SEARCH_THUMBNAIL_WIDTH * 2;
const SEARCH_THUMBNAIL_ASPECT_RATIO = 4 / 3;

async function getThumbnailUrls() {
	if (!imageId) return;

	const getImageById = await getImageByIdFunction();
	const imageEntry = getImageById(imageId);

	if (!imageEntry) return;

	const getSignedIpxPath = createSignedIpxPathFunction({
		imageQuality: IMAGE_QUALITY,
		imageFormat: IMAGE_FORMAT,
		serverSecret: IPX_SERVER_SECRET,
	});

	const fit = ImageFitOptionEnum.Cover;

	return {
		url1x: `${IPX_SERVER_URL}${getSignedIpxPath(imageId, {
			width: SEARCH_THUMBNAIL_WIDTH,
			height: Math.round(SEARCH_THUMBNAIL_WIDTH / SEARCH_THUMBNAIL_ASPECT_RATIO),
			fit,
		})}`,
		url2x: `${IPX_SERVER_URL}${getSignedIpxPath(imageId, {
			width: SEARCH_THUMBNAIL_WIDTH_2X,
			height: Math.round(SEARCH_THUMBNAIL_WIDTH_2X / SEARCH_THUMBNAIL_ASPECT_RATIO),
			fit,
		})}`,
	};
}

const thumbnails = await getThumbnailUrls();
---

<article {...props} {...hideSearch ? {} : { 'data-pagefind-body': '' }}>
	<slot />
	{
		thumbnails ? (
			<>
				<meta data-pagefind-meta="image[content]" content={thumbnails.url1x} />
				<meta data-pagefind-meta="image_2x[content]" content={thumbnails.url2x} />
			</>
		) : (
			<meta data-pagefind-meta="image[content]" content="" />
		)
	}
</article>
