---
import type { MapComponentData } from '@spectralcodex/react-map-component';
import type { Page } from 'astro';
import type { CollectionEntry } from 'astro:content';

import { stripDiacritics } from '@spectralcodex/shared/text';

import type { ContentMetadataItem } from '#lib/metadata/metadata-types.ts';

import ContentArticle from '#components/content/content-article.astro';
import ContentCollectionLink from '#components/content/content-collection-link.astro';
import ContentDescription from '#components/content/content-description.astro';
import ContentHeader from '#components/content/content-header.astro';
import ImageHeroCarousel from '#components/image/image-hero-carousel.astro';
import MainSite from '#components/main/main-site.astro';
import DividedItem from '#components/parts/divided-item.astro';
import TextMultilingual from '#components/parts/text-multilingual.astro';
import SectionLinks from '#components/sections/section-links.astro';
import SectionMap from '#components/sections/section-map.astro';
import SectionMetadataGrid from '#components/sections/section-metadata-grid.astro';
import SectionMetadataList from '#components/sections/section-metadata-list.astro';
import SectionRegions from '#components/sections/section-regions.astro';
import SectionSources from '#components/sections/section-sources.astro';
import SectionThemes from '#components/sections/section-themes.astro';
import { getMultilingualContent } from '#lib/i18n/i18n-utils.ts';
import { getImageFeaturedGroup, getImageFeaturedId } from '#lib/image/image-featured.ts';
import { getContentMetadataIndex } from '#lib/metadata/metadata-index.ts';
import { getSeoHideSearch, getSeoImageProps } from '#lib/utils/seo.ts';

interface Props {
	entry: CollectionEntry<'themes'>;
	mapData: MapComponentData;
	metadataItems: Array<ContentMetadataItem>;
	metadataItemsCount: number;
	relatedThemeIds: Array<string>;
	page: Page<ContentMetadataItem>;
}

const { entry, mapData, metadataItems, metadataItemsCount, relatedThemeIds, page } = Astro.props;

const titleMultilingual = getMultilingualContent({ data: entry.data, prop: 'title' })?.primary;

const regionIds = entry.data.regions?.map(({ id }) => id);
const themeIds = entry.data.themes?.map(({ id }) => id);
const allThemeIds = [...new Set([...(themeIds ?? []), ...relatedThemeIds])];

const contentMetadataIndex = await getContentMetadataIndex();

const imageFeaturedGroup = getImageFeaturedGroup({
	imageFeatured: entry.data.imageFeatured,
	contentMetadataIndex,
});

const imageFeaturedId = getImageFeaturedId({ imageFeatured: entry.data.imageFeatured });

const hasHeroImage = !!imageFeaturedGroup && imageFeaturedGroup.length > 0;
---

<MainSite
	meta={{
		title: titleMultilingual
			? `${entry.data.title} (${titleMultilingual.value})`
			: entry.data.title,
		description: entry.data.description ?? entry.body ?? undefined,
		image: await getSeoImageProps({
			id: entry.id,
			alt: entry.data.title,
		}),
		...getSeoHideSearch(entry.data.hideSearch),
		prefetchUrls: mapData.prefetchUrls,
	}}
	hasHeroImage={hasHeroImage}
>
	<ContentArticle
		imageId={imageFeaturedId}
		hideSearch={!!entry.data.hideSearch || page.currentPage !== 1}
	>
		<ImageHeroCarousel
			class="sm:mb-4"
			hasHeroImage={hasHeroImage}
			imageFeaturedGroup={imageFeaturedGroup}
		>
			<ContentHeader hasHeroImage={hasHeroImage}>
				<Fragment slot="header-title">{stripDiacritics(entry.data.title)}</Fragment>
				<Fragment slot="header-title-multilingual">
					<TextMultilingual content={titleMultilingual} />
				</Fragment>
				<Fragment slot="header-subtitle">
					<DividedItem hasHeroImage={hasHeroImage}>
						<ContentCollectionLink collection={entry.collection} hasHeroImage={hasHeroImage} />
					</DividedItem>
				</Fragment>
			</ContentHeader>
		</ImageHeroCarousel>
		<ContentDescription entry={entry} />
		<SectionMap mapData={mapData} />
		<SectionLinks entry={entry} />
		<SectionSources entry={entry} />
		<SectionRegions regionIds={regionIds} />
		<SectionThemes themeIds={allThemeIds} />
		<SectionMetadataGrid page={page} />
		{
			page.currentPage === 1 && metadataItems.length > 0 ? (
				<SectionMetadataList items={metadataItems} count={metadataItemsCount} />
			) : undefined
		}
	</ContentArticle>
</MainSite>
