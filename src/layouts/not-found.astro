---
import { transformMarkdown } from '@xsynaptic/unified-tools';

import ContentHeader from '#components/content/content-header.astro';
import ContentSection from '#components/content/content-section.astro';
import MainSite from '#components/main/main-site.astro';
import NotFoundSuggestions from '#components/not-found/not-found-suggestions.astro';
import { getTranslations } from '#lib/i18n/i18n-translations.ts';
import { getSeoHideSearch } from '#lib/utils/seo.ts';
import { getSeoImageProps } from '#lib/utils/seo.ts';

const t = getTranslations();

const title = t('notFound.title');
const description = t('notFound.description');
---

<MainSite
	meta={{
		title,
		description,
		image: await getSeoImageProps({
			id: 'index-not-found',
			alt: title,
		}),
		...getSeoHideSearch(true),
	}}
>
	<ContentHeader>
		<Fragment slot="header-title">{title}</Fragment>
	</ContentHeader>
	<ContentSection>
		<Fragment slot="section-description"
			><Fragment set:html={transformMarkdown({ input: description })} />
			<NotFoundSuggestions /></Fragment
		>
	</ContentSection>
</MainSite>
