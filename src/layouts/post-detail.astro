---
import type { MapComponentData } from '@spectralcodex/react-map-component';
import type { CollectionEntry } from 'astro:content';

import { stripDiacritics } from '@spectralcodex/shared/text';
import { render } from 'astro:content';

import type { CatalogItem } from '#lib/catalog/catalog-types.ts';

import ContentArticle from '#components/content/content-article.astro';
import ContentCollectionLink from '#components/content/content-collection-link.astro';
import ContentDate from '#components/content/content-date.astro';
import ContentHeader from '#components/content/content-header.astro';
import ImageHero from '#components/image/image-hero.astro';
import MainSite from '#components/main/main-site.astro';
import DividedItem from '#components/parts/divided-item.astro';
import Prose from '#components/parts/prose.astro';
import TextMultilingual from '#components/parts/text-multilingual.astro';
import SectionAuthor from '#components/sections/section-author.astro';
import SectionBacklinks from '#components/sections/section-backlinks.astro';
import SectionCitation from '#components/sections/section-citation.astro';
import SectionLinks from '#components/sections/section-links.astro';
import SectionMap from '#components/sections/section-map.astro';
import SectionRegions from '#components/sections/section-regions.astro';
import SectionSeries from '#components/sections/section-series.astro';
import SectionSimilar from '#components/sections/section-similar.astro';
import SectionSources from '#components/sections/section-sources.astro';
import SectionThemes from '#components/sections/section-themes.astro';
import { getCatalog } from '#lib/catalog/catalog-data.ts';
import { getPostSchema } from '#lib/collections/posts/posts-utils.ts';
import { getMultilingualContent } from '#lib/i18n/i18n-utils.ts';
import { getImageFeaturedHeroGroup, getImageFeaturedId } from '#lib/image/image-featured.ts';
import { DatePresetEnum } from '#lib/utils/date.ts';
import { getDescriptionRenderedText } from '#lib/utils/description.ts';
import { MicroformatClassNames } from '#lib/utils/microformats.ts';
import { getSeoArticleProps, getSeoHideSearch, getSeoImageProps } from '#lib/utils/seo.ts';

interface Props {
	entry: CollectionEntry<'posts'>;
	mapData: MapComponentData;
	backlinks: Array<CatalogItem> | undefined;
}

const { entry, mapData, backlinks } = Astro.props;

const titleMultilingual = getMultilingualContent({ data: entry.data, prop: 'title' })?.primary;

const regionIds = entry.data.regions?.map(({ id }) => id);
const themeIds = entry.data.themes?.map(({ id }) => id);

const catalog = await getCatalog();
const imageFeaturedHeroGroup = getImageFeaturedHeroGroup({
	imageFeatured: entry.data.imageFeatured,
	getCaption: catalog.getCaption,
});
const imageFeaturedId = getImageFeaturedId({ imageFeatured: entry.data.imageFeatured });

const hasHeroImage = !!imageFeaturedHeroGroup && imageFeaturedHeroGroup.length > 0;

const { Content } = await render(entry);

const seoImage = getSeoImageProps({ id: entry.id, alt: entry.data.title });
---

<MainSite
	meta={{
		title: titleMultilingual
			? `${entry.data.title} (${titleMultilingual.value})`
			: entry.data.title,
		description: await getDescriptionRenderedText(entry),
		image: seoImage,
		...getSeoArticleProps({
			dateCreated: entry.data.dateCreated,
			dateUpdated: entry.data.dateUpdated,
		}),
		...getSeoHideSearch(entry.data.hideSearch),
		prefetchUrls: mapData.prefetchUrls,
	}}
	schemas={await getPostSchema(entry, { url: Astro.url.toString(), imageUrl: seoImage.url })}
	hasHeroImage={hasHeroImage}
>
	<ContentArticle
		class={MicroformatClassNames.Entry}
		imageId={imageFeaturedId}
		hideSearch={entry.data.hideSearch}
	>
		<ImageHero
			class="sm:mb-4"
			imageFeaturedGroup={imageFeaturedHeroGroup}
			fallbackAlt={entry.data.title}
		>
			<ContentHeader hasHeroImage={hasHeroImage}>
				<Fragment slot="header-title">
					<a href={Astro.url.toString()} class="p-name p-url" aria-hidden="true" tabindex="-1"
						>{stripDiacritics(entry.data.title)}</a
					>
				</Fragment>
				<Fragment slot="header-title-multilingual">
					<TextMultilingual content={titleMultilingual} />
				</Fragment>
				<Fragment slot="header-subtitle">
					<DividedItem>
						<ContentCollectionLink collection="posts" hasHeroImage={hasHeroImage} />
					</DividedItem>
					<DividedItem>
						<ContentDate
							date={entry.data.dateCreated}
							datePreset={DatePresetEnum.Medium}
							showMicroformats={true}
						/>
					</DividedItem>
					{
						entry.data.dateUpdated ? (
							<DividedItem>
								<ContentDate
									date={entry.data.dateUpdated}
									datePreset={DatePresetEnum.Medium}
									showMicroformats={true}
									showUpdated={true}
								/>
							</DividedItem>
						) : undefined
					}
				</Fragment>
			</ContentHeader>
		</ImageHero>
		<Prose class:list={['e-content', 'pb-4']} showBlocks={true} data-reading-frame>
			<Content />
		</Prose>
		<SectionMap mapData={mapData} />
		<SectionLinks entry={entry} />
		<SectionSources entry={entry} />
		<SectionThemes themeIds={themeIds} />
		<SectionRegions regionIds={regionIds} />
		<SectionSeries entry={entry} />
		<SectionBacklinks backlinks={backlinks} />
		<SectionSimilar entry={entry} showPreviews={true} limit={8} />
		<SectionAuthor showAuthor={false} />
		{import.meta.env.DEV ? <SectionCitation entry={entry} /> : undefined}
	</ContentArticle>
</MainSite>
