---
import type { Page } from 'astro';

import { transformMarkdown } from '@xsynaptic/unified-tools';

import type { CatalogItem } from '#lib/catalog/catalog-types.ts';

import ContentHeader from '#components/content/content-header.astro';
import ContentSection from '#components/content/content-section.astro';
import MainSite from '#components/main/main-site.astro';
import MetadataGrid from '#components/parts/metadata-grid.astro';
import PaginationSelect from '#components/parts/pagination-select.astro';
import { getTranslations } from '#lib/i18n/i18n-translations.ts';
import { getSeoImageProps } from '#lib/utils/seo.ts';

interface Props {
	page: Page<CatalogItem>;
}

const { page } = Astro.props;

const t = getTranslations();

const title = t('collection.series.labelPlural');
const description = t('collection.series.description');
---

<MainSite
	meta={{
		title,
		description,
		image: getSeoImageProps({
			id: 'index-series',
			alt: title,
		}),
		noIndex: page.currentPage > 1,
	}}
>
	<ContentHeader>
		<Fragment slot="header-title">{title}</Fragment>
	</ContentHeader>
	<ContentSection>
		<Fragment slot="section-description" set:html={transformMarkdown({ input: description })} />
		<MetadataGrid items={page.data} showDescription={true} />
		<PaginationSelect class="mt-4 md:mt-8" page={page} />
	</ContentSection>
</MainSite>
