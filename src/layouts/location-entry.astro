---
import type { MapComponentData } from '@spectralcodex/react-map-component';
import type { CollectionEntry } from 'astro:content';

import { stripDiacritics } from '@spectralcodex/shared/text';

import type { ContentMetadataItem } from '#lib/metadata/metadata-types.ts';

import ContentArticle from '#components/content/content-article.astro';
import ContentCollectionLink from '#components/content/content-collection-link.astro';
import ContentDate from '#components/content/content-date.astro';
import ContentDescription from '#components/content/content-description.astro';
import ContentHeader from '#components/content/content-header.astro';
import ContentImage from '#components/content/content-image.astro';
import ImageHero from '#components/image/image-hero.astro';
import LocationsAddress from '#components/locations/locations-address.astro';
import SectionDateVisited from '#components/locations/locations-section-date-visited.astro';
import SectionHeritage from '#components/locations/locations-section-heritage.astro';
import SectionNearbyList from '#components/locations/locations-section-nearby-list.astro';
import SectionNotices from '#components/locations/locations-section-notices.astro';
import MainSite from '#components/main/main-site.astro';
import DividedItem from '#components/parts/divided-item.astro';
import TextMultilingual from '#components/parts/text-multilingual.astro';
import RegionsBreadcrumbs from '#components/regions/regions-breadcrumbs.astro';
import SectionAuthor from '#components/sections/section-author.astro';
import SectionBacklinks from '#components/sections/section-backlinks.astro';
import SectionLinks from '#components/sections/section-links.astro';
import SectionMap from '#components/sections/section-map.astro';
import SectionMetadataGrid from '#components/sections/section-metadata-grid.astro';
import SectionRelated from '#components/sections/section-related.astro';
import SectionSeries from '#components/sections/section-series.astro';
import SectionSources from '#components/sections/section-sources.astro';
import SectionThemes from '#components/sections/section-themes.astro';
import {
	createLocationEntryDisplayFunction,
	getLocationSchemas,
} from '#lib/collections/locations/locations-utils.ts';
import { getImageFeaturedId, getImageFeaturedHeroId } from '#lib/image/image-featured.ts';
import { getHasContent } from '#lib/utils/astro.ts';
import { getPublicId } from '#lib/utils/collections.ts';
import { DatePresetEnum } from '#lib/utils/date.ts';
import { MicroformatClassNames } from '#lib/utils/microformats.ts';
import { getSeoHideSearch, getSeoImageProps } from '#lib/utils/seo.ts';
import { getDescription } from '#lib/utils/text.ts';

interface Props {
	entry: CollectionEntry<'locations'>;
	mapData: MapComponentData;
	metadataItems: Array<ContentMetadataItem>;
	backlinks: Array<ContentMetadataItem> | undefined;
}

const { entry, mapData, metadataItems, backlinks } = Astro.props;

const getLocationEntryDisplay = await createLocationEntryDisplayFunction();
const { regionPrimary, regionLangCode, titleMultilingual, titleMultilingualAdditional } =
	getLocationEntryDisplay(entry);

const themeIds = entry.data.themes?.map(({ id }) => id);

const hasContent = getHasContent(entry);
const imageFeaturedId = getImageFeaturedId({
	imageFeatured: entry.data.imageFeatured,
});
const imageHeroId = getImageFeaturedHeroId(entry.data.imageFeatured);

const hasHeroImage = !!imageHeroId;

const hideLocation = entry.data.hideLocation && !import.meta.env.DEV;
---

<MainSite
	meta={{
		title: titleMultilingual
			? `${entry.data.title} (${titleMultilingual.value})`
			: entry.data.title,
		description: getDescription(entry),
		image: await getSeoImageProps({
			id: getPublicId(entry),
			alt: entry.data.title,
		}),
		...getSeoHideSearch(entry.data.hideSearch),
	}}
	schemas={await getLocationSchemas(entry, { url: Astro.url.toString() })}
	hasHeroImage={hasHeroImage}
>
	<ContentArticle
		class={MicroformatClassNames.Entry}
		imageId={imageFeaturedId}
		hideSearch={entry.data.hideSearch}
	>
		<ImageHero
			class="sm:mb-4"
			hasHeroImage={hasHeroImage}
			imageId={imageHeroId}
			alt={entry.data.title}
		>
			<ContentHeader hasHeroImage={hasHeroImage}>
				<Fragment slot="header-title">
					<a href={Astro.url.toString()} class="p-name p-url" aria-hidden="true" tabindex="-1"
						>{stripDiacritics(entry.data.title)}</a
					>
				</Fragment>
				<Fragment slot="header-title-multilingual">
					<TextMultilingual content={titleMultilingual} additional={titleMultilingualAdditional} />
				</Fragment>
				<Fragment slot="header-subtitle">
					<DividedItem hasHeroImage={hasHeroImage}>
						<ContentCollectionLink collection="locations" hasHeroImage={hasHeroImage} />
					</DividedItem>
					{
						regionPrimary ? (
							<DividedItem hasHeroImage={hasHeroImage}>
								<RegionsBreadcrumbs
									entry={regionPrimary}
									showCurrentLink={true}
									hasHeroImage={hasHeroImage}
								/>
							</DividedItem>
						) : undefined
					}
					<DividedItem hasHeroImage={hasHeroImage}>
						<ContentDate
							date={entry.data.dateCreated}
							datePreset={DatePresetEnum.Medium}
							showMicroformats={true}
						/>
					</DividedItem>
					{
						entry.data.dateUpdated ? (
							<DividedItem hasHeroImage={hasHeroImage}>
								<ContentDate
									date={entry.data.dateUpdated}
									datePreset={DatePresetEnum.Medium}
									showMicroformats={true}
									showUpdated={true}
								/>
							</DividedItem>
						) : undefined
					}
				</Fragment>
			</ContentHeader>
		</ImageHero>
		{
			!hasContent && !hasHeroImage && imageFeaturedId ? (
				<ContentImage
					imageId={imageFeaturedId}
					alt={entry.data.title}
					priority={true}
					showMetadata={true}
				/>
			) : undefined
		}
		<ContentDescription
			class="e-content"
			entry={entry}
			{...hasContent ? { 'data-reading-frame': '' } : {}}
		/>
		<SectionNotices entry={entry} langCode={regionLangCode} />
		{
			hideLocation ? undefined : (
				<SectionMap mapData={mapData}>
					<LocationsAddress address={entry.data.address} />
				</SectionMap>
			)
		}
		<SectionHeritage heritage={entry.data.heritage} />
		{hideLocation ? undefined : <SectionDateVisited dateVisited={entry.data.dateVisited} />}
		{hideLocation ? undefined : <SectionLinks entry={entry} />}
		{hideLocation ? undefined : <SectionSources entry={entry} />}
		<SectionThemes themeIds={themeIds} />
		<SectionSeries entry={entry} />
		<SectionBacklinks backlinks={backlinks} />
		<SectionMetadataGrid items={metadataItems} />
		<SectionRelated entry={entry} showPreviews={true} limit={8} />
		<SectionNearbyList entry={entry} limit={12} />
		<SectionAuthor showAuthor={false} />
	</ContentArticle>
</MainSite>
