---
import type { MapComponentData } from '@spectralcodex/react-map-component';

import ContentHeader from '#components/content/content-header.astro';
import ContentSection from '#components/content/content-section.astro';
import MainSite from '#components/main/main-site.astro';
import SectionMap from '#components/sections/section-map.astro';
import { renderMarkdownInline } from '#lib/utils/markdown.ts';
import { getSeoHideSearch } from '#lib/utils/seo.ts';

type Props = MapComponentData;

const mapData = Astro.props;

const title = 'Objectives';
const description = 'Points in the database that still require visitation and documentation.';
---

<MainSite meta={{ title, description, ...getSeoHideSearch(true) }}>
	<ContentHeader>
		<Fragment slot="header-title">{title}</Fragment>
	</ContentHeader>
	<ContentSection>
		<Fragment slot="section-description" set:html={renderMarkdownInline(description)} />
	</ContentSection>
	<SectionMap mapData={mapData} />
</MainSite>
