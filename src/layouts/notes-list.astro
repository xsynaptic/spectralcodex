---
import type { Page } from 'astro';
import type { CollectionEntry } from 'astro:content';

import { render } from 'astro:content';

import ContentDate from '#components/content/content-date.astro';
import ContentExcerpt from '#components/content/content-excerpt.astro';
import ContentHeader from '#components/content/content-header.astro';
import ContentSection from '#components/content/content-section.astro';
import MainSite from '#components/main/main-site.astro';
import DividedItem from '#components/parts/divided-item.astro';
import PaginationCounter from '#components/parts/pagination-counter.astro';
import PaginationSelect from '#components/parts/pagination-select.astro';
import { getTranslations } from '#lib/i18n/i18n-translations.ts';
import { DatePresetEnum } from '#lib/utils/date.ts';
import { getContentUrl } from '#lib/utils/routing.ts';
import { getSeoImageProps } from '#lib/utils/seo.ts';
import { renderMarkdownInline } from '#lib/utils/text.ts';

interface Props {
	page: Page<CollectionEntry<'notes'>>;
}

const { page } = Astro.props;

const t = getTranslations();

const title = t('collection.notes.labelPlural');
const description = t('collection.notes.description');
---

<MainSite
	meta={{
		title,
		description,
		image: getSeoImageProps({
			id: 'index-notes',
			alt: title,
		}),
		noIndex: page.currentPage > 1,
	}}
>
	<ContentHeader>
		<Fragment slot="header-title">{title}</Fragment>
		<Fragment slot="header-subtitle"><PaginationCounter page={page} /></Fragment>
	</ContentHeader>
	<ContentSection>
		<Fragment
			slot="section-description"
			set:html={page.currentPage === 1 ? renderMarkdownInline(description) : undefined}
		/>
	</ContentSection>
	{
		page.data.length > 0
			? page.data.map(async (entry, index) => {
					const { Content } = await render(entry);

					return (
						<ContentExcerpt
							entryUrl={getContentUrl(entry.collection, entry.id)}
							showDivider={index + 1 < page.data.length}
						>
							<Fragment slot="excerpt-title">{entry.data.title}</Fragment>
							<Fragment slot="excerpt-subtitle">
								<DividedItem>
									<ContentDate date={entry.data.dateCreated} datePreset={DatePresetEnum.Medium} />
								</DividedItem>
								{entry.data.dateUpdated ? (
									<DividedItem>
										<ContentDate
											date={entry.data.dateUpdated}
											datePreset={DatePresetEnum.Medium}
											showUpdated={true}
										/>
									</DividedItem>
								) : undefined}
							</Fragment>
							<Content />
						</ContentExcerpt>
					);
				})
			: undefined
	}
	<ContentSection>
		<PaginationSelect class="mt-4 md:mt-8" page={page} />
	</ContentSection>
</MainSite>
