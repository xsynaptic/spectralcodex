---
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';

import RegionEntry from '#layouts/region-entry.astro';
import { getRegionsCollection } from '#lib/collections/regions/regions-data.ts';
import { createQueryRegionsEntryFunction } from '#lib/collections/regions/regions-data.ts';

export const getStaticPaths = (async ({ paginate }) => {
	const { entries } = await getRegionsCollection();

	const queryRegionsEntry = await createQueryRegionsEntryFunction();

	const results = [];

	for (const entry of entries) {
		const { metadataItemsFiltered, mapData, metadataItems, metadataItemsCount, regionsOption } =
			queryRegionsEntry(entry);

		results.push(
			...paginate(metadataItemsFiltered, {
				params: { id: entry.id },
				props: {
					entry,
					mapData,
					metadataItems,
					metadataItemsCount,
					regionsOption,
				},
				pageSize: 20,
			}),
		);
	}

	return results;
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
---

<RegionEntry {...Astro.props} />
