---
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';

import ThemeEntry from '#layouts/theme-entry.astro';
import { getThemesCollection } from '#lib/collections/themes/themes-data.ts';
import { createQueryThemesEntryFunction } from '#lib/collections/themes/themes-utils.ts';

export const getStaticPaths = (async ({ paginate }) => {
	const { entries: themes } = await getThemesCollection();

	const queryThemesEntry = await createQueryThemesEntryFunction();

	const results = [];

	for (const entry of themes) {
		const { metadataItemsFiltered, metadataItems, metadataItemsCount, mapData, relatedThemeIds } =
			queryThemesEntry(entry);

		results.push(
			...paginate(metadataItemsFiltered, {
				params: { id: entry.id },
				props: { entry, mapData, metadataItems, metadataItemsCount, relatedThemeIds },
				pageSize: 20,
			}),
		);
	}
	return results;
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
---

<ThemeEntry {...Astro.props} />
