---
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';

import NotesDetail from '#layouts/notes-detail.astro';
import { getCatalog } from '#lib/catalog/catalog-data.ts';
import { getNotesCollection } from '#lib/collections/notes/notes-data.ts';

export const getStaticPaths = (async () => {
	const { entries } = await getNotesCollection();

	const catalog = await getCatalog();

	return entries.map((entry) => ({
		params: { note: entry.id },
		props: {
			entry,
			backlinks: catalog.backlinksOf(entry.id),
		},
	}));
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
---

<NotesDetail {...Astro.props} />
