---
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';

import NotesEntry from '#layouts/notes-entry.astro';
import { getNotesCollection } from '#lib/collections/notes/notes-data.ts';
import { createContentBacklinksFunction } from '#lib/metadata/metadata-backlinks.ts';

export const getStaticPaths = (async () => {
	const { entries } = await getNotesCollection();

	const getContentBacklinks = await createContentBacklinksFunction();

	return entries.map((entry) => ({
		params: { note: entry.id },
		props: {
			entry,
			backlinks: getContentBacklinks({ id: entry.id }),
		},
	}));
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
---

<NotesEntry {...Astro.props} />
