---
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';

import NotesIndex from '#layouts/notes-index.astro';
import { queryNotesIndex } from '#lib/collections/notes/notes-data.ts';

export const getStaticPaths = (async ({ paginate }) => {
	const results = await queryNotesIndex();

	return paginate(results, { pageSize: 10 });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
---

<NotesIndex {...Astro.props} />
