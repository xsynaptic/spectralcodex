---
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';

import NotesList from '#layouts/notes-list.astro';
import { queryNotesIndex } from '#lib/collections/notes/notes-utils.ts';

export const getStaticPaths = (async ({ paginate }) => {
	const results = await queryNotesIndex();

	return paginate(results, { pageSize: 10 });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
---

<NotesList {...Astro.props} />
