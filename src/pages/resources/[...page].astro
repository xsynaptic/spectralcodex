---
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';

import ResourcesList from '#layouts/resources-list.astro';
import { queryResourcesIndex } from '#lib/collections/resources/resources-utils.ts';

export const getStaticPaths = (async ({ paginate }) => {
	const results = await queryResourcesIndex();

	return paginate(results, { pageSize: 50 });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
---

<ResourcesList {...Astro.props} />
