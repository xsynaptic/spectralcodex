---
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';

import ResourcesDetail from '#layouts/resources-detail.astro';
import { getResourcesCollection } from '#lib/collections/resources/resources-data.ts';
import { createQueryResourcesEntryFunction } from '#lib/collections/resources/resources-utils.ts';

export const getStaticPaths = (async ({ paginate }) => {
	const { entries } = await getResourcesCollection();

	const entriesPublic = entries.filter((entry) => !!entry.data.showPage);

	const queryResourcesEntry = await createQueryResourcesEntryFunction();

	const results = [];

	for (const entry of entriesPublic) {
		const { catalogItems, mapData } = queryResourcesEntry(entry);

		results.push(
			...paginate(catalogItems, {
				params: { id: entry.id },
				props: { entry, mapData },
				pageSize: 20,
			}),
		);
	}
	return results;
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
---

<ResourcesDetail {...Astro.props} />
