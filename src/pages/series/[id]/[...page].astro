---
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';

import SeriesEntry from '#layouts/series-entry.astro';
import { getSeriesCollection } from '#lib/collections/series/series-data.ts';
import { createQuerySeriesEntryFunction } from '#lib/collections/series/series-utils.ts';

export const getStaticPaths = (async ({ paginate }) => {
	const { entries: series } = await getSeriesCollection();

	const querySeriesEntry = await createQuerySeriesEntryFunction();

	const results = [];

	for (const entry of series) {
		const result = querySeriesEntry(entry);

		if (!result) continue;

		const { metadataItems, mapData, wordCount } = result;

		results.push(
			...paginate(metadataItems, {
				params: { id: entry.id },
				props: { entry, mapData, wordCount },
				pageSize: 20,
			}),
		);
	}
	return results;
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
---

<SeriesEntry {...Astro.props} />
