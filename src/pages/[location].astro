---
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';

import LocationEntry from '#layouts/location-entry.astro';
import { getLocationsCollection } from '#lib/collections/locations/locations-data.ts';
import { createQueryLocationsEntryFunction } from '#lib/collections/locations/locations-utils.ts';

export const getStaticPaths = (async () => {
	const { entries } = await getLocationsCollection();

	const queryLocationsEntry = await createQueryLocationsEntryFunction();

	return entries.map((entry) => {
		const { mapData, metadataItems, backlinks } = queryLocationsEntry(entry);

		return {
			params: { location: entry.data.override?.slug ?? entry.id },
			props: { entry, mapData, metadataItems, backlinks },
		};
	});
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
---

<LocationEntry {...Astro.props} />
