---
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';

import LocationDetail from '#layouts/location-detail.astro';
import { getLocationsCollection } from '#lib/collections/locations/locations-data.ts';
import { createQueryLocationsEntryFunction } from '#lib/collections/locations/locations-utils.ts';
import { getPublicId } from '#lib/utils/collections.ts';

export const getStaticPaths = (async () => {
	const { entries } = await getLocationsCollection();

	const queryLocationsEntry = await createQueryLocationsEntryFunction();

	return entries.map((entry) => {
		const { mapData, catalogItems, backlinks } = queryLocationsEntry(entry);

		return {
			params: { location: getPublicId(entry) },
			props: { entry, mapData, catalogItems, backlinks },
		};
	});
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
---

<LocationDetail {...Astro.props} />
