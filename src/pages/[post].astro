---
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro';

import PostDetail from '#layouts/post-detail.astro';
import { getPostsCollection } from '#lib/collections/posts/posts-data.ts';
import { createQueryPostsEntryFunction } from '#lib/collections/posts/posts-utils.ts';

export const getStaticPaths = (async () => {
	const { entries } = await getPostsCollection();

	const queryPostsEntry = await createQueryPostsEntryFunction();

	return entries.map((entry) => {
		const { mapData, backlinks } = queryPostsEntry(entry);

		return {
			params: { post: entry.id },
			props: { entry, mapData, backlinks },
		};
	});
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
---

<PostDetail {...Astro.props} />
