{
	"name": "@xsynaptic/spectralcodex",
	"version": "6.8.2",
	"scripts": {
		"dev": "tsx packages/scripts/src/dev-server/index.ts",
		"build": "astro check && NODE_OPTIONS=--max-old-space-size=8192 astro build",
		"lint": "eslint",
		"lint-strict": "ESLINT_STRICT=1 eslint",
		"check-content": "pnpm --filter @spectralcodex/content check",
		"check-content-demo": "pnpm --filter @spectralcodex/content-demo check",
		"format-content": "pnpm --filter @spectralcodex/content format",
		"knip": "knip",
		"test": "vitest",
		"test:e2e": "playwright test",
		"test:image-server": "vitest run --config vitest.integration.config.ts",
		"check": "prettier --write . && tsc --noEmit && astro check && eslint --fix && knip",
		"check-types": "tsc --noEmit --extendedDiagnostics",
		"content-related": "pnpm --filter @spectralcodex/scripts content-related --root-path=$PWD",
		"content-schemas": "pnpm --filter @spectralcodex/scripts content-schemas --root-path=$PWD --output-path=packages/content",
		"content-validate": "pnpm --filter @spectralcodex/scripts content-validate --root-path=$PWD",
		"map-divisions": "pnpm --filter @spectralcodex/scripts map-divisions --root-path=$PWD",
		"media-orphans": "pnpm --filter @spectralcodex/scripts media-orphans --root-path=$PWD",
		"og-image": "pnpm --filter @spectralcodex/scripts og-image --root-path=$PWD",
		"generate-redirects": "pnpm --filter @spectralcodex/scripts generate-redirects --root-path=$PWD",
		"deploy-site": "pnpm --filter @spectralcodex/scripts deploy-site --root-path=$PWD",
		"deploy-app": "pnpm --filter @spectralcodex/scripts deploy-app --root-path=$PWD",
		"deploy-caddy": "pnpm --filter @spectralcodex/scripts deploy-caddy --root-path=$PWD",
		"deploy-image-server": "pnpm --filter @spectralcodex/scripts deploy-image-server --root-path=$PWD",
		"deploy-media": "pnpm --filter @spectralcodex/scripts deploy-media --root-path=$PWD",
		"deploy-og": "pnpm --filter @spectralcodex/scripts deploy-og --root-path=$PWD",
		"cache-warm": "pnpm --filter @spectralcodex/scripts image-server-warm --root-path=$PWD",
		"cache-warm-new": "pnpm --filter @spectralcodex/scripts image-server-warm-new --root-path=$PWD",
		"check-links": "pnpm --filter @spectralcodex/scripts check-links --root-path=$PWD"
	},
	"type": "module",
	"license": "MIT",
	"browserslist": [
		"> 0.5%",
		"last 2 versions",
		"not ie 11",
		"not ie_mob 11",
		"not dead"
	],
	"imports": {
		"#*": "./src/*"
	},
	"dependencies": {
		"astro": "^6.1.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4"
	},
	"devDependencies": {
		"@astrojs/markdown-remark": "^7.1.0",
		"@astrojs/mdx": "^5.0.3",
		"@astrojs/node": "^10.0.4",
		"@astrojs/react": "^5.0.2",
		"@astrojs/rss": "^4.0.18",
		"@astrojs/sitemap": "^3.7.2",
		"@pagefind/default-ui": "^1.4.0",
		"@playwright/test": "^1.58.2",
		"@spectralcodex/astro-build-logger": "workspace:*",
		"@spectralcodex/astro-image-loader": "workspace:*",
		"@spectralcodex/astro-pagefind": "workspace:*",
		"@spectralcodex/react-map-component": "workspace:*",
		"@spectralcodex/react-search-component": "workspace:*",
		"@spectralcodex/remark-img-group": "workspace:*",
		"@spectralcodex/scripts": "workspace:*",
		"@spectralcodex/shared": "workspace:*",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@tanstack/eslint-plugin-query": "^5.95.2",
		"@turf/bbox": "^7.3.4",
		"@turf/buffer": "^7.3.4",
		"@turf/center": "^7.3.4",
		"@turf/centroid": "^7.3.4",
		"@turf/distance": "^7.3.4",
		"@turf/helpers": "^7.3.4",
		"@turf/truncate": "^7.3.4",
		"@types/geojson": "^7946.0.16",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@unpic/astro": "^1.0.2",
		"@unpic/core": "^1.0.3",
		"@xsynaptic/eslint-config": "^3.2.1",
		"@xsynaptic/image-server": "workspace:*",
		"@xsynaptic/unified-tools": "^3.0.2",
		"alfaaz": "^1.1.0",
		"astro-auto-import": "^0.5.1",
		"astro-seo": "^1.1.0",
		"dotenv": "^17.3.1",
		"eslint": "^9.39.4",
		"eslint-plugin-astro": "^1.6.0",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-react-hooks": "^7.0.1",
		"exiftool-vendored": "^35.15.1",
		"geojson": "^0.5.0",
		"geokdbush": "^2.0.1",
		"globals": "^17.4.0",
		"kdbush": "^4.0.2",
		"knip": "^6.0.5",
		"maplibre-gl": "^5.21.1",
		"p-limit": "^7.3.0",
		"p-memoize": "^8.0.0",
		"prettier": "^3.8.1",
		"prettier-plugin-astro": "^0.14.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"rehype-wrap-cjk": "^1.0.10",
		"remeda": "^2.33.6",
		"sharp": "^0.34.5",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.2",
		"unified": "^11.0.5",
		"unpic": "^4.2.2",
		"url-join": "^5.0.0",
		"vite": "^7.3.1",
		"vitest": "^4.1.1",
		"yaml": "^2.8.3",
		"zod": "^4.3.6"
	},
	"packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
