{
	"name": "@xsynaptic/spectralcodex",
	"version": "6.17.0",
	"scripts": {
		"build": "astro check && NODE_OPTIONS=--max-old-space-size=8192 astro build",
		"check-content": "pnpm --filter @spectralcodex/content check",
		"check-content-demo": "pnpm --filter @spectralcodex/content-demo check",
		"check-links": "pnpm -F @spectralcodex/scripts check-links",
		"check-types": "tsc --noEmit --extendedDiagnostics",
		"content-schemas": "pnpm --filter @spectralcodex/scripts content-schemas --output-path=packages/content",
		"deploy-app": "pnpm -F @spectralcodex/scripts deploy-app",
		"deploy-caddy": "pnpm -F @spectralcodex/scripts deploy-caddy",
		"deploy-image-server": "pnpm -F @spectralcodex/scripts deploy-image-server",
		"deploy-media": "pnpm -F @spectralcodex/scripts deploy-media",
		"deploy-og": "pnpm -F @spectralcodex/scripts deploy-og",
		"deploy-site": "pnpm -F @spectralcodex/scripts deploy-site",
		"dev": "pnpm -F @spectralcodex/scripts dev-server",
		"format": "prettier --write . && eslint --fix && tsc --noEmit --extendedDiagnostics && astro check && knip",
		"format-content": "pnpm --filter @spectralcodex/content format",
		"generate-redirects": "pnpm -F @spectralcodex/scripts generate-redirects",
		"image-server-warm": "pnpm -F @spectralcodex/scripts image-server-warm",
		"image-server-warm-new": "pnpm -F @spectralcodex/scripts image-server-warm-new",
		"improve-content": "pnpm -F @spectralcodex/scripts improve-content",
		"knip": "knip",
		"lint": "eslint",
		"lint-strict": "ESLINT_STRICT=1 eslint",
		"map-divisions": "pnpm -F @spectralcodex/scripts map-divisions",
		"media-orphans": "pnpm -F @spectralcodex/scripts media-orphans",
		"og-image": "pnpm -F @spectralcodex/scripts og-image",
		"similar-content": "pnpm -F @spectralcodex/scripts similar-content",
		"test": "vitest",
		"test-e2e": "playwright test",
		"test-e2e-prod": "TEST_ENV=prod node --env-file-if-exists=.env node_modules/@playwright/test/cli.js test",
		"test-image-server": "vitest run --config vitest.integration.config.ts",
		"validate-content": "pnpm -F @spectralcodex/scripts validate-content"
	},
	"type": "module",
	"license": "MIT",
	"browserslist": [
		"> 0.5%",
		"last 2 versions",
		"not ie 11",
		"not ie_mob 11",
		"not dead"
	],
	"imports": {
		"#*": "./src/*"
	},
	"dependencies": {
		"astro": "^6.3.5",
		"react": "^19.2.6",
		"react-dom": "^19.2.6"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"@astrojs/markdown-remark": "^7.1.2",
		"@astrojs/mdx": "^5.0.6",
		"@astrojs/node": "^10.1.1",
		"@astrojs/react": "^5.0.5",
		"@astrojs/rss": "^4.0.18",
		"@astrojs/sitemap": "^3.7.2",
		"@pagefind/component-ui": "^1.5.2",
		"@playwright/test": "^1.60.0",
		"@spectralcodex/astro-build-logger": "workspace:*",
		"@spectralcodex/astro-image-loader": "workspace:*",
		"@spectralcodex/astro-pagefind": "workspace:*",
		"@spectralcodex/react-map-component": "workspace:*",
		"@spectralcodex/remark-img-group": "workspace:*",
		"@spectralcodex/scripts": "workspace:*",
		"@spectralcodex/shared": "workspace:*",
		"@spectralcodex/word-count": "workspace:*",
		"@tailwindcss/vite": "^4.3.0",
		"@tanstack/eslint-plugin-query": "^5.100.11",
		"@turf/bbox": "^7.3.5",
		"@turf/buffer": "^7.3.5",
		"@turf/center": "^7.3.5",
		"@turf/centroid": "^7.3.5",
		"@turf/distance": "^7.3.5",
		"@turf/helpers": "^7.3.5",
		"@turf/truncate": "^7.3.5",
		"@types/geojson": "^7946.0.16",
		"@types/react": "^19.2.15",
		"@types/react-dom": "^19.2.3",
		"@unpic/astro": "^1.0.2",
		"@unpic/core": "^1.0.3",
		"@xsynaptic/eslint-config": "^3.3.2",
		"@xsynaptic/image-server": "workspace:*",
		"@xsynaptic/unified-tools": "^4.2.1",
		"astro-auto-import": "^0.5.1",
		"astro-seo": "^1.1.0",
		"eslint": "^9.39.4",
		"eslint-plugin-astro": "^1.7.0",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-react-hooks": "^7.1.1",
		"exiftool-vendored": "^35.20.0",
		"fastest-levenshtein": "^1.0.16",
		"geokdbush": "^2.1.0",
		"globals": "^17.6.0",
		"kdbush": "^4.1.0",
		"knip": "^6.14.1",
		"maplibre-gl": "^5.24.0",
		"p-limit": "^7.3.0",
		"p-memoize": "^8.0.0",
		"prettier": "^3.8.3",
		"prettier-plugin-astro": "^0.14.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"rehype-wrap-cjk": "^2.1.2",
		"remeda": "^2.34.1",
		"sharp": "^0.34.5",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.22.3",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.59.4",
		"unified": "^11.0.5",
		"unpic": "^4.2.2",
		"vite": "^7.3.3",
		"vitest": "^4.1.7",
		"zod": "^4.4.3"
	},
	"packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499"
}
