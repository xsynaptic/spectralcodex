{
	"name": "@xsynaptic/spectralcodex",
	"version": "6.27.0",
	"scripts": {
		"build": "astro check && NODE_OPTIONS=--max-old-space-size=8192 astro build",
		"check-content": "pnpm -F @spectralcodex/scripts format-content packages/content",
		"check-content-demo": "pnpm -F @spectralcodex/scripts format-content packages/content-demo",
		"check-links": "pnpm -F @spectralcodex/scripts check-links",
		"check-types": "tsc --noEmit --extendedDiagnostics",
		"content-schemas": "pnpm --filter @spectralcodex/scripts content-schemas --output-path=packages/content",
		"deploy-app": "pnpm -F @spectralcodex/scripts deploy-app",
		"deploy-caddy": "pnpm -F @spectralcodex/scripts deploy-caddy",
		"deploy-image-server": "pnpm -F @spectralcodex/scripts deploy-image-server",
		"deploy-media": "pnpm -F @spectralcodex/scripts deploy-media",
		"deploy-og": "pnpm -F @spectralcodex/scripts deploy-og",
		"deploy-site": "pnpm -F @spectralcodex/scripts deploy-site",
		"dev": "pnpm -F @spectralcodex/scripts dev-server",
		"format": "stylelint \"src/**/*.{css,astro}\" --fix && prettier --write . && eslint --fix && tsc --noEmit --extendedDiagnostics && astro check && knip",
		"format-content": "pnpm -F @spectralcodex/scripts format-content packages/content --fix",
		"format-content-demo": "pnpm -F @spectralcodex/scripts format-content packages/content-demo --fix",
		"generate-redirects": "pnpm -F @spectralcodex/scripts generate-redirects",
		"image-server-warm": "pnpm -F @spectralcodex/scripts image-server-warm",
		"image-server-warm-new": "pnpm -F @spectralcodex/scripts image-server-warm-new",
		"improve-content": "pnpm -F @spectralcodex/scripts improve-content",
		"knip": "knip",
		"lint": "eslint",
		"lint-css": "stylelint \"src/**/*.{css,astro}\"",
		"lint-css-fix": "stylelint \"src/**/*.{css,astro}\" --fix",
		"lint-strict": "ESLINT_STRICT=1 eslint",
		"map-divisions": "pnpm -F @spectralcodex/scripts map-divisions",
		"media-orphans": "pnpm -F @spectralcodex/scripts media-orphans",
		"og-image": "pnpm -F @spectralcodex/scripts og-image",
		"similar-content": "pnpm -F @spectralcodex/scripts similar-content",
		"test": "vitest",
		"test-e2e": "playwright test",
		"test-e2e-prod": "TEST_ENV=prod node --env-file-if-exists=.env node_modules/@playwright/test/cli.js test",
		"test-image-server": "vitest run --config vitest.integration.config.ts",
		"validate-content": "astro sync && pnpm -F @spectralcodex/scripts validate-content"
	},
	"type": "module",
	"license": "MIT",
	"browserslist": [
		"> 0.5%",
		"last 2 versions",
		"not ie 11",
		"not ie_mob 11",
		"not dead"
	],
	"imports": {
		"#*": "./src/*"
	},
	"dependencies": {
		"astro": "^6.4.4",
		"react": "^19.2.7",
		"react-dom": "^19.2.7"
	},
	"devDependencies": {
		"@astrojs/check": "^0.9.9",
		"@astrojs/markdown-remark": "^7.2.0",
		"@astrojs/mdx": "^6.0.2",
		"@astrojs/node": "^10.1.3",
		"@astrojs/react": "^5.0.7",
		"@astrojs/rss": "^4.0.18",
		"@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
		"@pagefind/component-ui": "^1.5.2",
		"@playwright/test": "^1.60.0",
		"@spectralcodex/astro-build-logger": "workspace:*",
		"@spectralcodex/astro-image-loader": "workspace:*",
		"@spectralcodex/astro-pagefind": "workspace:*",
		"@spectralcodex/astro-sitemap": "workspace:*",
		"@spectralcodex/react-map-component": "workspace:*",
		"@spectralcodex/remark-img-group": "workspace:*",
		"@spectralcodex/scripts": "workspace:*",
		"@spectralcodex/shared": "workspace:*",
		"@spectralcodex/word-count": "workspace:*",
		"@tailwindcss/vite": "^4.3.0",
		"@tanstack/eslint-plugin-query": "^5.101.0",
		"@turf/bbox": "^7.3.5",
		"@turf/buffer": "^7.3.5",
		"@turf/center": "^7.3.5",
		"@turf/centroid": "^7.3.5",
		"@turf/distance": "^7.3.5",
		"@turf/helpers": "^7.3.5",
		"@turf/truncate": "^7.3.5",
		"@types/geojson": "^7946.0.16",
		"@types/react": "^19.2.16",
		"@types/react-dom": "^19.2.3",
		"@unpic/astro": "^1.0.2",
		"@unpic/core": "^1.0.3",
		"@xsynaptic/eslint-config": "^3.4.0",
		"@xsynaptic/rehype-wrap-cjk": "^3.0.0",
		"@xsynaptic/remark-auto-import": "^1.0.0",
		"@xsynaptic/stylelint-config": "^0.1.1",
		"@xsynaptic/unified-tools": "^5.0.0",
		"@xsynaptic/unpic-imagor": "^0.1.0",
		"astro-seo": "^1.1.0",
		"eslint": "^9.39.4",
		"eslint-plugin-astro": "^1.7.0",
		"eslint-plugin-jsx-a11y": "^6.10.2",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-wc": "^3.1.0",
		"exiftool-vendored": "^36.0.0",
		"fastest-levenshtein": "^1.0.16",
		"geokdbush": "^2.1.0",
		"globals": "^17.6.0",
		"kdbush": "^4.1.0",
		"knip": "^6.15.0",
		"maplibre-gl": "^5.24.0",
		"p-limit": "^7.3.0",
		"p-memoize": "^8.0.0",
		"prettier": "^3.8.3",
		"prettier-plugin-astro": "^0.14.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"remeda": "^2.37.0",
		"sharp": "^0.34.5",
		"stylelint": "^17.12.0",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"unified": "^11.0.5",
		"unpic": "^4.2.2",
		"vite": "^7.3.5",
		"vitest": "^4.1.8",
		"zod": "^4.4.3"
	},
	"packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485"
}
